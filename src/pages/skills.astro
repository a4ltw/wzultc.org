---
import Layout from '../layouts/Layout.astro';
import videosData from '../data/videos.json';
import courseTitlesData from '../data/courseTitles.json';

type VideoInfo = {
  title: string;
  lang: string;
  langLabel: string;
  type: string;
  count: number;
  youtubeId?: string;
};

// 課程標題（各語言），去除括號內的中文說明
const courseTitles = courseTitlesData as Record<string, Record<string, string>>;
function cleanTitle(t: string): string {
  // 去除結尾的 (中文說明) 括號
  return t.replace(/\s*[（(][^）)]*[）)]\s*$/, '').trim();
}

const COURSE_ORDER = ['Y01','Y02','Y03','A01','A02','B01','B02','C01','C02','C03','C04','F01','F02','F03','D01','D02','D03','D04','D05','D06','D07','D08'];

const SERIES_LABEL: Record<string, string> = {
  Y: '居家護理（高榮衛教）',
  A: '防護操作',
  B: '醫療器材操作',
  C: '移動照護',
  F: '個人衛生照護',
  D: '失智症照護',
};

const TYPE_LABEL: Record<string, Record<string, string>> = {
  S: { ZH: '簡報', VI: 'Bài trình bày', ID: 'Presentasi' },
  P: { ZH: '流程圖', VI: 'Sơ đồ', ID: 'Diagram Alur' },
  V: { ZH: '影片', VI: 'Video', ID: 'Video' },
};

const LANG_COLOR: Record<string, string> = {
  ZH: 'bg-blue-100 text-blue-700',
  VI: 'bg-yellow-100 text-yellow-700',
  ID: 'bg-red-100 text-red-700',
};

const grouped: Record<string, { title: string; codes: [string, VideoInfo][] }> = {};
for (const [code, info] of Object.entries(videosData) as [string, VideoInfo][]) {
  const course = code.split('-')[0];
  if (!grouped[course]) grouped[course] = { title: info.title, codes: [] };
  grouped[course].codes.push([code, info]);
}

function sortCodes(codes: [string, VideoInfo][]) {
  const typeOrder: Record<string, number> = { V: 0, S: 1, P: 2 };
  return codes.sort(([a, ai], [b, bi]) => {
    const aT = typeOrder[ai.type] ?? 9;
    const bT = typeOrder[bi.type] ?? 9;
    if (aT !== bT) return aT - bT;
    const langOrder = ['ZH', 'VI', 'ID'];
    const li = langOrder.indexOf(ai.lang) - langOrder.indexOf(bi.lang);
    if (li !== 0) return li;
    return a.localeCompare(b);
  });
}

const seriesGroups: Record<string, string[]> = {};
for (const course of COURSE_ORDER) {
  if (!grouped[course]) continue;
  const series = course[0];
  if (!seriesGroups[series]) seriesGroups[series] = [];
  seriesGroups[series].push(course);
}
---

<Layout title="專技教材 - WZULTC" description="長照專業技術教材，含簡報與流程圖，提供中文、越南語、印尼語版本">
  <!-- Hero -->
  <div class="bg-gradient-to-r from-blue-600 to-cyan-500 text-white py-10 text-center px-4">
    <h1 class="text-3xl md:text-4xl font-bold mb-3">長照專技教材</h1>
    <p class="text-lg opacity-90">Tài liệu kỹ thuật chăm sóc dài hạn ／ Materi teknis perawatan jangka panjang</p>
    <div class="flex justify-center gap-3 mt-5 flex-wrap">
      <button data-lang="ZH" class="lang-btn active px-5 py-2 rounded-full font-semibold text-sm border-2 border-white bg-white text-blue-600 transition-all">
        中文
      </button>
      <button data-lang="VI" class="lang-btn px-5 py-2 rounded-full font-semibold text-sm border-2 border-white/60 text-white/90 bg-white/10 hover:bg-white/20 transition-all">
        Tiếng Việt
      </button>
      <button data-lang="ID" class="lang-btn px-5 py-2 rounded-full font-semibold text-sm border-2 border-white/60 text-white/90 bg-white/10 hover:bg-white/20 transition-all">
        Bahasa Indonesia
      </button>
    </div>
  </div>

  <!-- Course list -->
  <div class="container mx-auto px-4 py-10 max-w-5xl">
    {Object.entries(seriesGroups).map(([series, courses]) => (
      <section class="series-section mb-12" data-series={series}>
        <h2 class="text-xl font-bold text-gray-700 mb-4 border-l-4 border-blue-500 pl-3">
          {SERIES_LABEL[series] ?? series}
        </h2>
        <div class="space-y-4">
          {courses.map((course) => {
            const { title, codes } = grouped[course];
            const sorted = sortCodes([...codes]);
            const courseLangs = [...new Set(sorted.map(([c]) => c.split('-')[1]))].join(' ');
            return (
              <div class="course-card bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden" data-langs={courseLangs}>
                <div class="bg-gradient-to-r from-blue-50 to-cyan-50 px-5 py-3 border-b border-gray-100">
                  <span class="font-mono text-xs text-blue-500 font-bold mr-2">{course}</span>
                  {(['ZH','VI','ID'] as const).map(lng => {
                    const t = courseTitles[course]?.[lng];
                    const display = t ? cleanTitle(t) : title;
                    return (
                      <span class="course-title font-semibold text-gray-800" data-title-lang={lng}
                        style={lng !== 'ZH' ? 'display:none' : ''}>
                        {display}
                      </span>
                    );
                  })}
                </div>
                {/* 嵌入影片區（各語言各一個，依語言篩選顯示） */}
                {sorted.filter(([, info]) => info.type === 'V' && info.youtubeId).map(([code, info]) => (
                  <div class="vid-embed border-b border-gray-100" data-embed-lang={info.lang}>
                    <div class="relative w-full" style="padding-top:56.25%">
                      <iframe
                        class="absolute inset-0 w-full h-full"
                        src={`https://www.youtube.com/embed/${info.youtubeId}`}
                        title={`${info.title}（${info.langLabel}）`}
                        frameborder="0"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                        allowfullscreen
                        loading="lazy"
                      ></iframe>
                    </div>
                  </div>
                ))}
                {/* S / P badges */}
                {sorted.some(([, info]) => info.type !== 'V') && (
                  <div class="px-5 py-4 flex flex-wrap gap-2">
                    {sorted.filter(([, info]) => info.type !== 'V').map(([code, info]) => {
                      const typeStr = code.split('-')[2] ?? '';
                      const typeBase = typeStr[0];
                      const typeLabels = TYPE_LABEL[typeBase] ?? { ZH: typeStr, VI: typeStr, ID: typeStr };
                      return (
                        <a
                          href={`/skills/${code}`}
                          data-badge-lang={info.lang}
                          data-type-zh={typeLabels['ZH']}
                          data-type-vi={typeLabels['VI']}
                          data-type-id={typeLabels['ID']}
                          class={`skill-badge inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg border text-sm font-medium transition-all hover:shadow-sm hover:-translate-y-0.5 ${LANG_COLOR[info.lang]} border-current/20`}
                        >
                          <span class="badge-type text-sm">{typeLabels[info.lang] ?? typeLabels['ZH']}</span>
                        </a>
                      );
                    })}
                  </div>
                )}
              </div>
            );
          })}
        </div>
      </section>
    ))}
  </div>

</Layout>

<script is:inline>
  const langBtns = document.querySelectorAll('.lang-btn');
  const cards    = document.querySelectorAll('.course-card');
  const sections = document.querySelectorAll('.series-section');

  function filterLang(lang) {
    langBtns.forEach(btn => {
      const on = btn.dataset.lang === lang;
      btn.classList.toggle('bg-white',       on);
      btn.classList.toggle('text-blue-600',  on);
      btn.classList.toggle('border-white',   on);
      btn.classList.toggle('bg-white/10',   !on);
      btn.classList.toggle('text-white/90', !on);
      btn.classList.toggle('border-white/60',!on);
    });

    // 課程標題切換
    document.querySelectorAll('.course-title').forEach(el => {
      el.style.display = el.dataset.titleLang === lang ? '' : 'none';
    });

    // Badge type label 切換
    const langKey = lang.toLowerCase();
    document.querySelectorAll('.badge-type').forEach(el => {
      const badge = el.closest('.skill-badge');
      if (!badge) return;
      const label = badge.dataset[`type${lang.charAt(0)}${lang.slice(1).toLowerCase()}`]
                 || badge.dataset['typeZh'] || '';
      el.textContent = label;
    });

    // S/P badges
    document.querySelectorAll('.skill-badge').forEach(b => {
      b.style.display = b.dataset.badgeLang === lang ? '' : 'none';
    });

    // 嵌入影片
    document.querySelectorAll('.vid-embed').forEach(v => {
      v.style.display = v.dataset.embedLang === lang ? '' : 'none';
    });

    // 卡片：有該語言內容才顯示
    cards.forEach(card => {
      const has = card.dataset.langs.split(' ').includes(lang);
      card.style.display = has ? '' : 'none';
    });

    // 系列區塊
    sections.forEach(sec => {
      const has = [...sec.querySelectorAll('.course-card')].some(c => c.style.display !== 'none');
      sec.style.display = has ? '' : 'none';
    });
  }

  langBtns.forEach(btn => btn.addEventListener('click', () => filterLang(btn.dataset.lang)));
  filterLang('ZH');
</script>
