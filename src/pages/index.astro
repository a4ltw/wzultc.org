---
import Layout from '../layouts/Layout.astro';
---

<Layout title="WZULTC - 文藻跨語照護計畫">
  <!-- Hero Banner -->
  <section class="bg-white">
    <img
      src="/assets/banner.jpg"
      alt="台灣長照產業跨域整合 - 跨國移工文化適應與專業照護技能升級，合作單位：文藻外語大學、國家科學及技術委員會、高雄榮民總醫院"
      class="w-full"
    />
    <div class="container mx-auto px-4">
      <div class="text-center py-6">
        <p class="text-lg md:text-xl text-gray-600 mb-4">
          培育跨域人才、深耕實踐場域
        </p>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 justify-center pb-8">
        <a href="/about" class="bg-gradient-to-r from-blue-500 via-cyan-500 to-teal-500 text-white px-8 py-3 rounded-lg font-semibold hover:from-blue-600 hover:to-teal-700 transition-all">
          了解計畫
        </a>
        <a href="/enroll" class="bg-gradient-to-r from-blue-500 to-cyan-500 text-white px-8 py-3 rounded-lg font-semibold hover:from-blue-600 hover:to-cyan-600 transition-all">
          加入我們
        </a>
      </div>
      </div>
  </section>

  <!-- 三大核心目標 Section -->
  <section class="py-16 container mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-12 text-gray-800">
      三大核心目標
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- 就醫無障礙 -->
      <div class="bg-white rounded-xl shadow-lg p-8 hover:shadow-xl transition-shadow">
        <div class="w-16 h-16 bg-gradient-to-br from-blue-500 via-cyan-500 to-teal-500 rounded-full flex items-center justify-center mb-4">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
        </div>
        <h3 class="text-xl font-bold mb-3 text-gray-800">就醫無障礙</h3>
        <p class="text-gray-600">
          高榮外籍人士就醫綠色通道，導入 AI 雙向翻譯系統，消除語言隔閡。
        </p>
      </div>

      <!-- CareConnect -->
      <div class="bg-white rounded-xl shadow-lg p-8 hover:shadow-xl transition-shadow">
        <div class="w-16 h-16 bg-gradient-to-br from-blue-500 to-cyan-600 rounded-full flex items-center justify-center mb-4">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold mb-3 text-gray-800">CareConnect</h3>
        <p class="text-gray-600">
          多國語智慧學習與 AI 互動平台，提供便捷的線上學習資源。
        </p>
      </div>

      <!-- 專技護升級 -->
      <div class="bg-white rounded-xl shadow-lg p-8 hover:shadow-xl transition-shadow">
        <div class="w-16 h-16 bg-gradient-to-br from-green-500 to-emerald-600 rounded-full flex items-center justify-center mb-4">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold mb-3 text-gray-800">專技護升級</h3>
        <p class="text-gray-600">
          華語/文化與多國語照護培訓，全面提升照護專業能力。
        </p>
      </div>
    </div>
  </section>

  <!-- 計畫成果 Section -->
  <section class="bg-gradient-to-br from-blue-50 to-cyan-50 py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-12 text-gray-800">
        計畫成果
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <!-- 活動場次 -->
        <div class="text-center">
          <div class="text-5xl md:text-6xl font-bold text-teal-600 mb-2">11+</div>
          <div class="text-xl text-gray-700">場活動</div>
        </div>
        <!-- 參與人次 -->
        <div class="text-center">
          <div class="text-5xl md:text-6xl font-bold text-blue-600 mb-2">290+</div>
          <div class="text-xl text-gray-700">人次參與</div>
        </div>
        <!-- 線上課程 -->
        <div class="text-center">
          <div class="text-5xl md:text-6xl font-bold text-cyan-600 mb-2">31</div>
          <div class="text-xl text-gray-700">堂線上課程</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Links Section -->
  <section class="bg-gray-100 py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-12 text-gray-800">
        快速導覽
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Link 1 -->
        <a href="/course" class="group bg-gradient-to-br from-blue-500 to-cyan-600 rounded-xl p-6 text-white hover:shadow-2xl transition-all hover:-translate-y-1">
          <h3 class="text-2xl font-bold mb-2">華語教材</h3>
          <p class="opacity-90">查看課程內容</p>
          <div class="mt-4 text-right">
            <svg class="w-6 h-6 inline-block group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </div>
        </a>

        <!-- Link 2 -->
        <a href="/enroll" class="group bg-gradient-to-br from-purple-500 to-indigo-600 rounded-xl p-6 text-white hover:shadow-2xl transition-all hover:-translate-y-1">
          <h3 class="text-2xl font-bold mb-2">招募資訊</h3>
          <p class="opacity-90">成為越南學伴</p>
          <div class="mt-4 text-right">
            <svg class="w-6 h-6 inline-block group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </div>
        </a>

        <!-- Link 3 -->
        <a href="/gallery" class="group bg-gradient-to-br from-blue-500 to-cyan-600 rounded-xl p-6 text-white hover:shadow-2xl transition-all hover:-translate-y-1">
          <h3 class="text-2xl font-bold mb-2">活動剪影</h3>
          <p class="opacity-90">精彩活動回顧</p>
          <div class="mt-4 text-right">
            <svg class="w-6 h-6 inline-block group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </div>
        </a>

        <!-- Link 4 -->
        <a href="/contact" class="group bg-gradient-to-br from-green-500 to-emerald-600 rounded-xl p-6 text-white hover:shadow-2xl transition-all hover:-translate-y-1">
          <h3 class="text-2xl font-bold mb-2">聯絡我們</h3>
          <p class="opacity-90">有任何問題？</p>
          <div class="mt-4 text-right">
            <svg class="w-6 h-6 inline-block group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 container mx-auto px-4">
    <div class="bg-gradient-to-r from-blue-500 via-cyan-500 to-teal-500 rounded-2xl p-12 text-center text-white">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        一起為跨文化交流貢獻心力
      </h2>
      <p class="text-lg md:text-xl mb-8 opacity-90">
        加入跨語照護計畫，成為台越文化交流的橋樑
      </p>
      <a href="/enroll" class="inline-block bg-white text-teal-600 px-10 py-4 rounded-lg font-bold text-lg hover:bg-gray-100 transition-colors">
        成為學伴
      </a>
    </div>
  </section>
</Layout>
