---
import Layout from '../layouts/Layout.astro';

const videos = [
  {
    lang: '中文',
    langSub: 'Chinese',
    youtubeId: '43TIuD-CdCc',
    shortUrl: 'https://wzultc.org/video/zh',
    color: 'sky',
  },
  {
    lang: '印尼語',
    langSub: 'Bahasa Indonesia',
    youtubeId: 'ewp13sfnF48',
    shortUrl: 'https://wzultc.org/video/id',
    color: 'red',
  },
  {
    lang: '越南語',
    langSub: 'Tiếng Việt',
    youtubeId: 'gfExMdsj7ho',
    shortUrl: 'https://wzultc.org/video/vi',
    color: 'yellow',
  },
];
---

<Layout title="教學影片 - WZULTC" description="文藻跨語照護計畫教學影片資源">
  <div class="container mx-auto px-4 py-12 max-w-4xl">
    <!-- Page Header -->
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-800 mb-4">
        教學影片
      </h1>
      <p class="text-xl text-gray-600">
        影音學習資源
      </p>
    </div>

    <!-- Video Cards -->
    <div class="flex flex-col gap-10">
      {videos.map((video) => (
        <div class="bg-white rounded-xl shadow-lg overflow-hidden">
          <!-- Language Badge -->
          <div class={`px-6 py-4 bg-${video.color}-50 border-b border-${video.color}-100 flex items-center gap-3`}>
            <span class={`text-lg font-bold text-${video.color}-700`}>{video.lang}</span>
            <span class="text-gray-500 text-sm">{video.langSub}</span>
          </div>
          <!-- YouTube Embed -->
          <div class="relative w-full" style="padding-top: 56.25%;">
            <iframe
              class="absolute inset-0 w-full h-full"
              src={`https://www.youtube.com/embed/${video.youtubeId}`}
              title={`教學影片 - ${video.lang}`}
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            ></iframe>
          </div>
          <!-- Short URL -->
          <div class="px-6 py-4 flex items-center gap-2 text-sm text-gray-500">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
            </svg>
            <span>短網址：</span>
            <a href={video.shortUrl} class="text-blue-600 hover:underline font-mono">{video.shortUrl}</a>
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>
