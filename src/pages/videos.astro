---
import Layout from '../layouts/Layout.astro';
---

<Layout title="影片資源 - WZULTC" description="文藻跨語照護計畫影片與教材資源中心">
  <div class="bg-gradient-to-r from-blue-600 to-cyan-500 text-white py-10 text-center px-4">
    <h1 class="text-3xl md:text-4xl font-bold mb-2">影片與教材資源</h1>
    <p class="text-lg opacity-90">Tài nguyên video và tài liệu học tập</p>
  </div>

  <div class="container mx-auto px-4 py-12 max-w-3xl space-y-6">
    <a href="/videos/general" class="block bg-white rounded-2xl shadow-md hover:shadow-lg transition-shadow border border-gray-100 overflow-hidden group">
      <div class="bg-gradient-to-r from-sky-500 to-teal-500 px-6 py-4">
        <h2 class="text-xl font-bold text-white">一般影片</h2>
        <p class="text-white/80 text-sm mt-1">健康檢查流程、跨文化講座、活動花絮</p>
      </div>
      <div class="px-6 py-4 flex justify-between items-center">
        <p class="text-gray-600 text-sm">衛教影片 ‧ 跨文化溝通系列 ‧ 活動紀錄</p>
        <span class="text-teal-500 group-hover:translate-x-1 transition-transform">→</span>
      </div>
    </a>

    <a href="/videos/skills" class="block bg-white rounded-2xl shadow-md hover:shadow-lg transition-shadow border border-gray-100 overflow-hidden group">
      <div class="bg-gradient-to-r from-blue-600 to-indigo-500 px-6 py-4">
        <h2 class="text-xl font-bold text-white">長照專技教材</h2>
        <p class="text-white/80 text-sm mt-1">Tài liệu kỹ thuật chăm sóc ／ Materi teknis perawatan</p>
      </div>
      <div class="px-6 py-4 flex justify-between items-center">
        <p class="text-gray-600 text-sm">簡報 ‧ 流程圖 ‧ 中文／越南語／印尼語</p>
        <span class="text-blue-500 group-hover:translate-x-1 transition-transform">→</span>
      </div>
    </a>
  </div>
</Layout>
