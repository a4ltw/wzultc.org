// 依日期排序，最新的在前面
const sortedEvents = events.sort((a, b) => b.date.localeCompare(a.date));
---

<Layout title="活動剪影 - WZULTC" description="文藻跨語照護計畫活動照片與精彩回顧">
  <div class="container mx-auto px-4 py-12 max-w-5xl">
    <!-- Page Header -->
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-800 mb-4">
        活動剪影
      </h1>
      <p class="text-xl text-gray-600">
        記錄我們的精彩時刻
      </p>
    </div>

    <!-- Events -->
    {sortedEvents.map((event) => (
      <article class="bg-white rounded-xl shadow-lg overflow-hidden mb-12">
        <!-- Event Header -->
        <div class="bg-gradient-to-r from-blue-500 via-cyan-500 to-teal-500 text-white p-6">
          <time class="text-cyan-200 text-sm">{event.date}</time>
          <h2 class="text-2xl md:text-3xl font-bold mt-1">{event.title}</h2>
        </div>

        <!-- Event Content -->
        <div class="p-6 md:p-8">
          <div class="prose prose-lg max-w-none text-gray-700 mb-8">
            {event.content.split('\n\n').map((paragraph) => (
              <p class="mb-4 leading-relaxed">{paragraph}</p>
            ))}
          </div>

          <!-- Photo Gallery -->
          {event.images.length > 0 && (
            <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
              {event.images.map((num) => (
                <a
                  href={`${event.imageFolder}/${num}.jpg`}
                  target="_blank"
                  class="block aspect-square overflow-hidden rounded-lg hover:opacity-90 transition-opacity"
                >
                  <img
                    src={`${event.imageFolder}/${num}.jpg`}
                    alt={`${event.title} 照片 ${num}`}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                </a>
              ))}
            </div>
          )}
        </div>
      </article>
    ))}
  </div>
</Layout>
