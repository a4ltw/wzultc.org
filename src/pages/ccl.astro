---
import Layout from '../layouts/Layout.astro';

const lectures = [
  { lang: '🇮🇩 印尼', vid: 'S_WhqxZ62-0', url: 'https://wzultc.org/video/ccl-id', title: '跨文化醫療溝通：提升醫護人員對印尼文化背景的理解與實踐', speaker: '魏愛妮（Yufita Ng）' },
  { lang: '🇹🇭 泰國', vid: 'U6_TJev2OsM', url: 'https://wzultc.org/video/ccl-th', title: '臨床實踐中的文化安全：連結泰國傳統價值觀與台灣醫療服務', speaker: '陳正娟（Anthika Manowong）' },
  { lang: '🇻🇳 越南', vid: 'n8TLFQ6FETE', url: 'https://wzultc.org/video/ccl-vi', title: '點頭不等於理解：越南病患的文化與醫療溝通', speaker: '阮氏玉蘭' },
  { lang: '🇵🇭 菲律賓', vid: 'MhEBgPXZFkk', url: 'https://wzultc.org/video/ccl-ph', title: '台灣醫護人員應了解的菲律賓外籍工作者照護重點：有效溝通的實用策略', speaker: '葉佰賢（Aiden Yeh）' },
];
---

<Layout title="跨文化講座 - WZULTC" description="醫護人員跨文化溝通系列講座">
  <div class="container mx-auto px-4 py-12 max-w-3xl">

    <div class="text-center mb-10">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-2">跨文化講座</h2>
      <p class="text-gray-500">醫護人員跨文化溝通系列</p>
    </div>

    <div class="space-y-10">
      {lectures.map(lec => (
        <div class="bg-white rounded-2xl shadow-md overflow-hidden">
          <div class="px-6 pt-5 pb-4">
            <p class="text-base font-semibold text-violet-500 mb-1">{lec.lang}</p>
            <p class="text-gray-800 font-medium leading-snug mb-1">{lec.title}</p>
            <p class="text-sm text-violet-600">{lec.speaker}</p>
          </div>
          <div class="relative w-full" style="padding-top: 56.25%;">
            <iframe class="absolute inset-0 w-full h-full"
              src={`https://www.youtube.com/embed/${lec.vid}`}
              title={lec.title} frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen></iframe>
          </div>
          <div class="px-6 py-3 border-t border-gray-100 flex items-center gap-2 text-sm text-gray-500">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
            </svg>
            <a href={lec.url} class="text-blue-600 hover:underline font-mono">{lec.url}</a>
          </div>
        </div>
      ))}
    </div>

  </div>
</Layout>
