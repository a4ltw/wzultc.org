---
import Layout from '../../layouts/Layout.astro';
import videosData from '../../data/videos.json';

export function getStaticPaths() {
  return Object.entries(videosData).map(([code, info]) => ({
    params: { code },
    props: { code, info },
  }));
}

const { code, info } = Astro.props;

const TYPE_LABEL: Record<string, string> = {
  S: '教學簡報',
  P: '流程圖／檢核表',
};

const TYPE_LABEL_VI: Record<string, string> = {
  S: 'Bài trình bày',
  P: 'Sơ đồ quy trình',
};

const TYPE_LABEL_ID: Record<string, string> = {
  S: 'Presentasi',
  P: 'Diagram alur',
};

const langLabelExtra = info.lang === 'VI'
  ? TYPE_LABEL_VI[info.type]
  : info.lang === 'ID'
  ? TYPE_LABEL_ID[info.type]
  : null;

const slides = Array.from({ length: info.count }, (_, i) => i + 1);
const basePath = `/videos/${code}`;
const pageTitle = `${info.title}｜${TYPE_LABEL[info.type]}（${info.langLabel}）`;
---

<Layout title={`${pageTitle} - WZULTC`} description={`${info.title} - ${TYPE_LABEL[info.type]}，${info.langLabel} 版本`}>
  <!-- Header -->
  <div class="bg-gradient-to-r from-blue-600 to-cyan-500 text-white py-8 text-center px-4">
    <div class="text-sm opacity-80 mb-1 font-mono">{code}</div>
    <h1 class="text-2xl md:text-3xl font-bold mb-2">{info.title}</h1>
    <div class="flex items-center justify-center gap-3 flex-wrap">
      <span class="inline-block px-3 py-1 bg-white/20 rounded-full text-sm font-medium">
        {TYPE_LABEL[info.type]}
        {langLabelExtra && <span class="opacity-80 ml-1">/ {langLabelExtra}</span>}
      </span>
      <span class="inline-block px-3 py-1 bg-white/20 rounded-full text-sm font-medium">
        {info.langLabel}
      </span>
      <span class="inline-block px-3 py-1 bg-white/20 rounded-full text-sm font-medium">
        {info.count} 頁
      </span>
    </div>
  </div>

  <!-- Nav bar -->
  <div id="vid-nav" class="bg-white shadow-sm border-b sticky top-14 z-40 transition-transform duration-300">
    <div class="container mx-auto px-4 py-3 flex flex-wrap justify-between items-center gap-2">
      <a href="/skills" class="text-blue-600 hover:text-blue-700 font-medium text-sm">
        ← 返回教材列表
      </a>
      <div class="flex gap-2 flex-wrap">
        <a
          href={`${basePath}/slide-01.jpg`}
          download={`${code}_slide-01.jpg`}
          class="text-xs px-3 py-1.5 border border-blue-300 text-blue-600 rounded hover:bg-blue-50 transition-colors"
        >
          ↓ 下載第 1 頁
        </a>
      </div>
    </div>
  </div>

  <!-- Slides -->
  <div class="container mx-auto px-4 py-8 max-w-4xl">
    {slides.map((n) => {
      const nn = String(n).padStart(2, '0');
      return (
        <div class="mb-8">
          <img
            src={`${basePath}/slide-${nn}.jpg`}
            alt={`第 ${n} 頁`}
            class="w-full rounded-lg shadow-lg bg-white"
            loading={n <= 2 ? 'eager' : 'lazy'}
          />
          <p class="text-center text-gray-400 text-xs mt-2">{n} / {info.count}</p>
        </div>
      );
    })}
  </div>

  <!-- Back to top -->
  <div class="text-center pb-10">
    <a href="#top" class="text-blue-500 hover:text-blue-600 text-sm">↑ 回到頂部</a>
    <span class="mx-3 text-gray-300">|</span>
    <a href="/skills" class="text-blue-500 hover:text-blue-600 text-sm">← 返回教材列表</a>
  </div>

  <script>
    const nav = document.getElementById('vid-nav');
    let last = window.scrollY;
    window.addEventListener('scroll', () => {
      const cur = window.scrollY;
      if (cur > last && cur > 100) nav?.classList.add('-translate-y-full');
      else nav?.classList.remove('-translate-y-full');
      last = cur;
    }, { passive: true });
  </script>
</Layout>
