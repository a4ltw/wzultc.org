---
import Layout from '../layouts/Layout.astro';
---

<Layout title="健康檢查流程 - WZULTC" description="外籍移工健康檢查流程教學影片，提供中文、越南語、印尼語版本">
  <div class="container mx-auto px-4 py-12 max-w-3xl">

    <div class="text-center mb-8">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-800 mb-2">健康檢查流程</h1>
      <p class="text-gray-500">Quy trình khám sức khỏe</p>
      <p class="text-gray-500">Proses Pemeriksaan Kesehatan</p>
    </div>

    <div class="flex justify-center gap-3 mb-6">
      <button data-vid="43TIuD-CdCc" data-url="https://wzultc.org/video/pcp-zh"
        class="pcp-btn px-6 py-2.5 rounded-full font-semibold text-sm transition-all border-2 border-sky-500 bg-sky-500 text-white">
        中文
      </button>
      <button data-vid="gfExMdsj7ho" data-url="https://wzultc.org/video/pcp-vi"
        class="pcp-btn px-6 py-2.5 rounded-full font-semibold text-sm transition-all border-2 border-sky-500 text-sky-600 bg-white hover:bg-sky-50">
        越南語
      </button>
      <button data-vid="ewp13sfnF48" data-url="https://wzultc.org/video/pcp-id"
        class="pcp-btn px-6 py-2.5 rounded-full font-semibold text-sm transition-all border-2 border-sky-500 text-sky-600 bg-white hover:bg-sky-50">
        印尼語
      </button>
    </div>

    <div class="bg-white rounded-2xl shadow-md overflow-hidden">
      <div class="relative w-full" style="padding-top: 56.25%;">
        <iframe id="pcp-frame" class="absolute inset-0 w-full h-full"
          src="https://www.youtube.com/embed/43TIuD-CdCc"
          title="健康檢查流程" frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen></iframe>
      </div>
      <div class="px-6 py-4 flex items-center gap-2 text-sm text-gray-500 border-t border-gray-100">
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
        </svg>
        <span>短網址：</span>
        <a id="pcp-url" href="https://wzultc.org/video/pcp-zh" class="text-blue-600 hover:underline font-mono">https://wzultc.org/video/pcp-zh</a>
      </div>
    </div>

  </div>
</Layout>

<script is:inline>
  document.querySelectorAll('.pcp-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.getElementById('pcp-frame').src = `https://www.youtube.com/embed/${btn.dataset.vid}`;
      const urlEl = document.getElementById('pcp-url');
      urlEl.href = btn.dataset.url;
      urlEl.textContent = btn.dataset.url;
      document.querySelectorAll('.pcp-btn').forEach(b => {
        const on = b === btn;
        b.classList.toggle('bg-sky-500', on);
        b.classList.toggle('text-white', on);
        b.classList.toggle('text-sky-600', !on);
        b.classList.toggle('bg-white', !on);
      });
    });
  });
</script>
