---
import Layout from '../layouts/Layout.astro';

const videos = [
  { lang: '中文', vid: '43TIuD-CdCc', url: 'https://wzultc.org/video/pcp-zh' },
  { lang: '越南語', vid: 'gfExMdsj7ho', url: 'https://wzultc.org/video/pcp-vi' },
  { lang: '印尼語', vid: 'ewp13sfnF48', url: 'https://wzultc.org/video/pcp-id' },
];
---

<Layout title="健康檢查流程 - WZULTC" description="外籍移工健康檢查流程教學影片，提供中文、越南語、印尼語版本">
  <div class="container mx-auto px-4 py-12 max-w-3xl">

    <div class="text-center mb-10">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-800 mb-2">健康檢查流程</h1>
      <p class="text-gray-500">Quy trình khám sức khỏe</p>
      <p class="text-gray-500">Proses Pemeriksaan Kesehatan</p>
    </div>

    <div class="space-y-10">
      {videos.map(v => (
        <div class="bg-white rounded-2xl shadow-md overflow-hidden">
          <div class="px-6 pt-5 pb-4">
            <p class="text-base font-semibold text-sky-500">{v.lang}</p>
          </div>
          <div class="relative w-full" style="padding-top: 56.25%;">
            <iframe class="absolute inset-0 w-full h-full"
              src={`https://www.youtube.com/embed/${v.vid}`}
              title={`健康檢查流程 ${v.lang}`} frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen></iframe>
          </div>
          <div class="px-6 py-3 border-t border-gray-100 flex items-center gap-2 text-sm text-gray-500">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
            </svg>
            <a href={v.url} class="text-blue-600 hover:underline font-mono">{v.url}</a>
          </div>
        </div>
      ))}
    </div>

  </div>
</Layout>
