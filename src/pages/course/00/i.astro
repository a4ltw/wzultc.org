// ════════════════════════════════════════

let currentIFAudio = null;
let currentIF = 'initial';

window.switchIF = function(mode) {
  currentIF = mode;
  const isInit = mode === 'initial';
  document.getElementById('btn-initial').className = `flex-1 py-2 rounded-xl text-sm font-bold transition-all ${isInit ? 'bg-sky-500 text-white' : 'bg-gray-100 text-gray-500'}`;
  document.getElementById('btn-final').className   = `flex-1 py-2 rounded-xl text-sm font-bold transition-all ${!isInit ? 'bg-indigo-500 text-white' : 'bg-gray-100 text-gray-500'}`;
  document.getElementById('if-empty').style.display = '';
  document.getElementById('if-detail').style.display = 'none';
  renderIFGrid(isInit ? INITIALS : FINALS, isInit ? 'sky' : 'indigo');
};

const IF_BTN_CLS = {
  sky:    'px-4 py-2 rounded-xl font-bold text-sky-700 bg-sky-50 border border-sky-200 hover:bg-sky-100 transition-colors text-sm',
  indigo: 'px-4 py-2 rounded-xl font-bold text-indigo-700 bg-indigo-50 border border-indigo-200 hover:bg-indigo-100 transition-colors text-sm',
};

function renderIFGrid(items, color) {
  const grid = document.getElementById('if-grid');
  const groups = [...new Set(items.map(it => it.group))];
  grid.innerHTML = groups.map(g => {
    const gItems = items.filter(it => it.group === g);
    return `
      <div class="mb-4">
        <p class="text-xs font-bold text-gray-400 mb-2 uppercase tracking-wider">${g}</p>
        <div class="flex flex-wrap gap-2">
          ${gItems.map(it => {
            const realIdx = items.indexOf(it);
            return `<button onclick="showIF(${realIdx})" class="${IF_BTN_CLS[color]}">${it.pinyin}</button>`;
          }).join('')}
        </div>
      </div>`;
  }).join('');
}

window.showIF = function(i) {
  const items = currentIF === 'initial' ? INITIALS : FINALS;
  const color  = currentIF === 'initial' ? 'sky' : 'indigo';
  const it = items[i];
  currentIFAudio = it.audio;
  document.getElementById('if-empty').style.display = 'none';
  const d = document.getElementById('if-detail');
  d.style.display = 'flex';
  const letterEl = document.getElementById('ifd-letter');
  letterEl.textContent = it.pinyin;
  letterEl.className = `text-4xl font-black ${color === 'sky' ? 'text-sky-600' : 'text-indigo-600'} leading-none`;
  document.getElementById('ifd-vn').textContent   = it.vn;
  document.getElementById('ifd-img').src          = `${BASE}/images/${it.img}`;
  document.getElementById('ifd-word').textContent = it.word;
  document.getElementById('ifd-pinyin').textContent = it.wp;
  document.getElementById('ifd-trans').textContent   = it.trans;
  const playBtn = document.querySelector('#if-detail button');
  if (playBtn) playBtn.className = `w-10 h-10 ${color === 'sky' ? 'bg-sky-500 hover:bg-sky-600' : 'bg-indigo-500 hover:bg-indigo-600'} rounded-full flex items-center justify-center flex-shrink-0 transition-colors shadow`;
  window.playAudio(it.audio);
};

window.playCurrentIF = function() {
  if (currentIFAudio) window.playAudio(currentIFAudio);
};

