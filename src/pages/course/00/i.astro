let currentToneAudio = null;

function renderTones() {
  const list = document.getElementById('tone-list');
  const markColors = ['bg-emerald-50 text-emerald-800', 'bg-sky-50 text-sky-800', 'bg-amber-50 text-amber-800', 'bg-red-50 text-red-800', 'bg-gray-50 text-gray-600'];
  list.innerHTML = TONES.map((t, i) => `
    <button onclick="showTone(${i})" class="w-full flex items-center gap-4 bg-white rounded-2xl shadow-sm border border-gray-100 px-4 py-4 hover:border-emerald-200 transition-all text-left active:scale-[0.98]">
      <div class="w-14 h-14 rounded-2xl ${markColors[i]} flex items-center justify-center flex-shrink-0">
        <span class="text-2xl font-black">${t.mark}</span>
      </div>
      <div class="flex-1 min-w-0">
        <p class="font-bold text-gray-800">${t.name}</p>
        <p class="text-xs text-gray-400">${t.vn}</p>
      </div>
      <div class="text-right flex-shrink-0">
        <p class="text-2xl font-black text-gray-700">${t.char}</p>
      </div>
      <svg class="flex-shrink-0 text-gray-300" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
    </button>
  `).join('');
}

window.showTone = function(i) {
  const t = TONES[i];
  currentToneAudio = t.audio;
  document.getElementById('tone-empty').style.display = 'none';
  const d = document.getElementById('tone-detail');
  d.style.display = 'flex';
  document.getElementById('td-curve').src  = `${BASE}/images/${t.toneImg}`;
  document.getElementById('td-name').textContent  = `${t.name} · ${t.vn}`;
  document.getElementById('td-desc').textContent  = t.desc;
  document.getElementById('td-char').textContent  = t.char;
  document.getElementById('td-img').src    = `${BASE}/images/${t.exImg}`;
  document.getElementById('td-word').textContent  = t.word;
  document.getElementById('td-pinyin').textContent = t.pinyin;
  document.getElementById('td-trans').textContent  = t.trans;
  window.playAudio(t.audio);
};

window.playCurrentTone = function() {
  if (currentToneAudio) window.playAudio(currentToneAudio);
};

