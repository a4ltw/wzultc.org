const quizState = { 1: { score:0, answered:0 }, 2: { score:0, answered:0 } };

function renderQuiz(questions, num) {
  const list = document.getElementById(`quiz${num}-list`);
  list.innerHTML = questions.map((q, qi) => {
    const typeIcon = q.type === 'image' ? '🖼️' : q.type === 'audio' ? '🔊' : '📝';
    const mediaHtml = q.type === 'image'
      ? `<img src="${BASE}/images/${q.media}" alt="" class="w-full rounded-2xl object-cover max-h-52 border border-gray-100" />`
      : q.type === 'audio'
      ? `<button onclick="window.playAudio('${q.media}')" class="w-full flex items-center justify-center gap-3 bg-sky-50 border border-sky-200 rounded-2xl py-4 hover:bg-sky-100 transition-colors">
          <div class="w-10 h-10 bg-sky-500 rounded-full flex items-center justify-center"><svg width="14" height="14" viewBox="0 0 24 24" fill="white"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>
          <span class="text-sm font-bold text-sky-700">播放題目音檔 / Phát âm</span>
        </button>`
      : '';
    return `
      <div class="quiz-card bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden" id="q${num}-card-${qi}" data-num="${num}" data-qi="${qi}" data-ans="${q.ans}" data-done="0">
        <div class="px-4 pt-4 pb-3">
          <div class="flex items-center gap-2 mb-3">
            <span class="w-7 h-7 rounded-full bg-teal-50 text-teal-700 text-xs font-bold flex items-center justify-center flex-shrink-0">${qi+1}</span>
            <span class="text-xs bg-gray-100 text-gray-500 px-2 py-0.5 rounded-full font-medium">${typeIcon}</span>
          </div>
          <p class="text-sm text-gray-700 font-medium mb-1">${q.q}</p>
          <p class="text-xs text-gray-400 mb-3">${q.qCh}</p>
          ${mediaHtml ? `<div class="mb-3">${mediaHtml}</div>` : ''}
          <div class="space-y-2" id="q${num}-opts-${qi}">
            ${q.opts.map((opt, oi) => `
              <button onclick="answerQ(${num},${qi},${oi})"
                class="w-full text-left px-4 py-3 rounded-xl border border-gray-200 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors"
                id="q${num}-opt-${qi}-${oi}">
                <span class="font-bold text-gray-400 mr-1">${['A','B','C'][oi]}.</span> ${opt}
              </button>`).join('')}
          </div>
          <div id="q${num}-explain-${qi}" style="display:none" class="mt-3 flex items-start gap-2 bg-amber-50 border border-amber-100 rounded-xl px-3 py-2">
            <span class="text-amber-500 flex-shrink-0">💡</span>
            <p class="text-xs text-amber-800">${q.ex}</p>
          </div>
        </div>
      </div>`;
  }).join('');
}

window.answerQ = function(num, qi, chosen) {
  const card = document.getElementById(`q${num}-card-${qi}`);
  if (card.dataset.done === '1') return;
  card.dataset.done = '1';
  const questions = num === 1 ? QUIZ1 : QUIZ2;
  const correct = parseInt(card.dataset.ans);
  const isRight = chosen === correct;
  const total = questions.length;
  // Style options
  [0,1,2].forEach(oi => {
    const btn = document.getElementById(`q${num}-opt-${qi}-${oi}`);
    if (!btn) return;
    btn.disabled = true;
    if (oi === correct) {
      btn.className = 'w-full text-left px-4 py-3 rounded-xl border text-sm font-medium bg-emerald-50 border-emerald-300 text-emerald-800';
      btn.innerHTML = `<span class="font-bold mr-1">✓</span> ${questions[qi].opts[oi]}`;
    } else if (oi === chosen && !isRight) {
      btn.className = 'w-full text-left px-4 py-3 rounded-xl border text-sm font-medium bg-red-50 border-red-200 text-red-700';
      btn.innerHTML = `<span class="font-bold mr-1">✗</span> ${questions[qi].opts[oi]}`;
    } else {
      btn.className = 'w-full text-left px-4 py-3 rounded-xl border text-sm font-medium bg-gray-50 border-gray-100 text-gray-400';
    }
  });
  document.getElementById(`q${num}-explain-${qi}`).style.display = 'flex';
  const st = quizState[num];
  st.answered++;
  if (isRight) st.score++;
  updateScore(num, total);
  if (st.answered === total) {
    setTimeout(() => {
      document.getElementById(`q${num}-summary`).style.display = '';
      document.getElementById(`q${num}-final-score`).textContent = `${st.score} / ${total} điểm · 分`;
    }, 600);
  }
};

function updateScore(num, total) {
  const st = quizState[num];
  document.getElementById(`q${num}-score-text`).textContent = `${st.score} / ${total}`;
  document.getElementById(`q${num}-progress`).style.width = `${(st.answered / total) * 100}%`;
}

window.resetQuiz = function(num) {
  quizState[num] = { score:0, answered:0 };
  const questions = num === 1 ? QUIZ1 : QUIZ2;
  updateScore(num, questions.length);
  document.getElementById(`q${num}-summary`).style.display = 'none';
  renderQuiz(questions, num);
};

// ════════════════════════════════════════
// TAB 4: PRACTICAL PINYIN
// ════════════════════════════════════════

let currentPracAudio = null;

function renderPractical() {
  const container = document.getElementById('hotspot-container');
  container.innerHTML = PRACTICAL.map((p, i) => `
    <button class="hotspot-btn" style="left:${p.x}%;top:${p.y}%;" onclick="showPrac(${i})" id="hspot-${i}">
      ${p.zh}
    </button>`).join('');
}

window.showPrac = function(i) {
  const p = PRACTICAL[i];
  currentPracAudio = p.audio;
  document.querySelectorAll('.hotspot-btn').forEach((b, bi) => b.classList.toggle('active', bi === i));
  document.getElementById('prac-empty').style.display = 'none';
  const w = document.getElementById('prac-word');
  w.style.display = 'flex';
  document.getElementById('prac-img').src        = `${BASE}/images/${p.img}`;
  document.getElementById('prac-zh').textContent     = p.zh;
  document.getElementById('prac-pinyin').textContent = p.pinyin;
  document.getElementById('prac-vn').textContent     = p.vn;
  window.playAudio(p.audio);
};

window.playCurrentPrac = function() {
  if (currentPracAudio) window.playAudio(currentPracAudio);
};

// ════════════════════════════════════════
// TAB 5: EXTENDED LEARNING (flip cards)
// ════════════════════════════════════════

function renderExtended() {
  const list = document.getElementById('extended-list');
  list.innerHTML = EXTENDED.map((it, i) => `
    <div class="flip-card h-32 rounded-2xl cursor-pointer" onclick="this.classList.toggle('flipped')" id="ext-${i}">
      <div class="flip-card-inner rounded-2xl shadow-sm">
        <div class="flip-card-front bg-teal-500 rounded-2xl flex items-center justify-between px-5">
          <div>
            <p class="text-white text-2xl font-black leading-tight">${it.zh}</p>
            <p class="text-teal-100 text-sm font-medium">${it.pinyin}</p>
          </div>
          <button onclick="event.stopPropagation(); window.playAudio('${it.audio}')"
            class="w-11 h-11 bg-white/20 hover:bg-white/30 rounded-full flex items-center justify-center flex-shrink-0 transition-colors">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="white"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          </button>
        </div>
        <div class="flip-card-back bg-teal-700 rounded-2xl flex items-center gap-4 px-5">
          <img src="${BASE}/images/${it.img}" alt="" class="w-20 h-20 object-contain rounded-xl bg-white/10 flex-shrink-0" />
          <div>
            <p class="text-teal-100 text-xs font-medium uppercase tracking-wider mb-1">Tiếng Việt</p>
            <p class="text-white text-xl font-bold leading-tight">${it.vn}</p>
          </div>
        </div>
      </div>
    </div>`).join('');
}

// ════════════════════════════════════════
// INIT
// ════════════════════════════════════════

renderTones();
switchIF('initial');
renderQuiz(QUIZ1, 1);
renderPractical();
renderExtended();
renderQuiz(QUIZ2, 2);
</script>
</Layout>
