];

const FINALS = [
  { pinyin:'a',   group:'a / o / e / ê',      vn:'a',                 word:'阿嬤', wp:'ā mà',      trans:'Bà',                   img:'L0_22.png',   audio:'L0_22.wav'   },
  { pinyin:'o',   group:'a / o / e / ê',      vn:'o',                 word:'脖子', wp:'bó zi',     trans:'Cổ',                   img:'L0_23.png',   audio:'L0_23.wav'   },
  { pinyin:'e',   group:'a / o / e / ê',      vn:'ơ',                 word:'餓',   wp:'è',         trans:'Đói',                  img:'L0_24.png',   audio:'L0_24.wav'   },
  { pinyin:'ê',   group:'a / o / e / ê',      vn:'ê',                 word:'噎到', wp:'yē dào',    trans:'Nghẹn / Sặc',          img:'L0_25.png',   audio:'L0_25.wav'   },
  { pinyin:'i',   group:'i / u / ü',          vn:'i',                 word:'點滴', wp:'diǎn dī',   trans:'Truyền dịch',          img:'L0_26-1.png', audio:'L0_26-1.wav' },
  { pinyin:'yi',  group:'i / u / ü',          vn:'i (đứng đầu)',      word:'醫院', wp:'yī yuàn',   trans:'Bệnh viện',            img:'L0_26-2.png', audio:'L0_26-2.wav' },
  { pinyin:'u',   group:'i / u / ü',          vn:'u',                 word:'吐',   wp:'tù',        trans:'Nôn / Ói',             img:'L0_27-1.png', audio:'L0_27-1.wav' },
  { pinyin:'wu',  group:'i / u / ü',          vn:'u (đứng đầu)',      word:'無力', wp:'wú lì',     trans:'Không có sức / Yếu',   img:'L0_27-8.png', audio:'L0_27-2.wav' },
  { pinyin:'ü',   group:'i / u / ü',          vn:'uy',                word:'女兒', wp:'nǚ ér',     trans:'Con gái',              img:'L0_28-1.png', audio:'L0_28-1.wav' },
  { pinyin:'yu',  group:'i / u / ü',          vn:'uy (đứng đầu)',     word:'浴室', wp:'yù shì',    trans:'Phòng tắm',            img:'L0_28-2.png', audio:'L0_28-2.wav' },
