  { pinyin:'r',  group:'zh / ch / sh / r', vn:'rư',              word:'熱水', wp:'rè shuǐ',   trans:'Nước nóng',                img:'L0_15.png', audio:'L0_15.wav' },
  { pinyin:'z',  group:'z / c / s',        vn:'chư',             word:'走路', wp:'zǒu lù',    trans:'Đi bộ',                    img:'L0_16.png', audio:'L0_16.wav' },
