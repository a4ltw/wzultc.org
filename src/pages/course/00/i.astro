---
import Layout from '../../../layouts/Layout.astro';
const BASE = '/assets/course/l0';
---

<Layout title="第零課 互動課程 - WZULTC" description="第零課聲調、聲韻母互動課程">
  <audio id="global-audio"></audio>

  <!-- ═══ Sticky Header ═══════════════════════════════════════════ -->
  <div class="sticky top-0 z-40 bg-white border-b border-gray-100 shadow-sm">
    <div class="max-w-md mx-auto flex items-center gap-3 px-4 pt-3 pb-1">
      <a href="/course/00" class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center flex-shrink-0">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
      </a>
      <div>
        <p class="text-sm font-bold text-gray-800 leading-tight">第零課・互動課程</p>
        <p class="text-xs text-gray-400">Bài học 0 · Tương tác</p>
      </div>
    </div>
    <!-- Tab Bar -->
    <div class="max-w-md mx-auto flex overflow-x-auto scrollbar-hide gap-1 px-3 pb-0 mt-1" id="tab-bar" style="scrollbar-width:none">
      {[
        { id:'tones',     zh:'聲調',  vn:'Thanh điệu' },
        { id:'initfinal', zh:'聲韻母', vn:'Phụ âm & vần' },
        { id:'quiz1',     zh:'練習①', vn:'Bài tập 1' },
        { id:'practical', zh:'拼音',   vn:'Luyện pinyin' },
        { id:'extended',  zh:'延伸',   vn:'Mở rộng' },
        { id:'quiz2',     zh:'練習②', vn:'Bài tập 2' },
      ].map((t, i) => (
        <button
          class={`tab-btn flex-shrink-0 flex flex-col items-center px-3 pb-2 pt-1 text-xs font-semibold border-b-2 transition-colors whitespace-nowrap ${i===0 ? 'border-teal-500 text-teal-600' : 'border-transparent text-gray-400'}`}
          data-tab={t.id}
          onclick={`switchTab('${t.id}')`}
        >
          <span class="text-sm font-bold">{t.zh}</span>
          <span class="text-[10px] leading-none mt-0.5 opacity-70">{t.vn}</span>
        </button>
      ))}
    </div>
  </div>

  <!-- ═══ Tab Content ════════════════════════════════════════════ -->
  <div class="max-w-md mx-auto">

  <!-- ── Tab 1: 聲調 ─────────────────────────────────────────── -->
  <section id="sec-tones" class="tab-section -mx-4">
    <div id="tone-list" class="overflow-y-auto px-4 pt-4 pb-3 space-y-3" style="max-height:52vh"></div>
    <div class="sticky bottom-0 bg-white rounded-t-3xl shadow-[0_-4px_24px_rgba(0,0,0,0.10)] border-t border-gray-100 px-5 py-4 z-20">
      <div id="tone-empty" class="flex flex-col items-center gap-1.5 py-4 text-gray-400">
        <p class="text-3xl">☝️</p>
        <p class="text-sm font-medium text-gray-500">請點選上方聲調</p>
        <p class="text-xs">Nhấn vào thanh điệu phía trên</p>
      </div>
      <div id="tone-detail" style="display:none" class="flex flex-col gap-3">
        <div class="flex items-start gap-4">
          <img id="td-curve" src="" alt="" class="w-28 h-20 object-contain rounded-xl bg-emerald-50 border border-emerald-100 flex-shrink-0" />
          <div class="flex-1 min-w-0">
            <p id="td-name" class="text-sm font-bold text-emerald-700"></p>
            <p id="td-desc" class="text-xs text-gray-500 mt-0.5"></p>
            <p id="td-char" class="text-4xl font-black text-gray-800 leading-tight mt-1"></p>
          </div>
        </div>
        <div class="flex items-center gap-3 bg-gray-50 rounded-2xl px-4 py-3">
          <img id="td-img" src="" alt="" class="w-14 h-14 object-contain rounded-xl bg-white border border-gray-100 flex-shrink-0" />
          <div class="flex-1 min-w-0">
            <p id="td-word" class="text-lg font-bold text-gray-800 leading-tight"></p>
            <p id="td-pinyin" class="text-sm text-emerald-600 font-medium"></p>
            <p id="td-trans" class="text-xs text-gray-500"></p>
          </div>
          <button onclick="window.playCurrentTone()" class="w-10 h-10 bg-emerald-500 hover:bg-emerald-600 rounded-full flex items-center justify-center flex-shrink-0 transition-colors shadow">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="white"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Tab 2: 聲韻母 ─────────────────────────────────────────── -->
  <section id="sec-initfinal" class="tab-section hidden -mx-4">
    <!-- Toggle -->
    <div class="flex gap-2 px-4 pt-4 pb-3 sticky top-[84px] z-10 bg-white border-b border-gray-100">
      <button id="btn-initial" onclick="switchIF('initial')" class="flex-1 py-2 rounded-xl text-sm font-bold bg-sky-500 text-white transition-all">聲母 <span class="font-normal text-xs opacity-80">Phụ âm</span></button>
      <button id="btn-final"   onclick="switchIF('final')"   class="flex-1 py-2 rounded-xl text-sm font-bold bg-gray-100 text-gray-500 transition-all">韻母 <span class="font-normal text-xs opacity-80">Vần</span></button>
    </div>
    <div id="if-grid" class="overflow-y-auto px-4 py-3" style="max-height:44vh"></div>
    <div class="sticky bottom-0 bg-white rounded-t-3xl shadow-[0_-4px_24px_rgba(0,0,0,0.10)] border-t border-gray-100 px-5 py-4 z-20">
      <div id="if-empty" class="flex flex-col items-center gap-1.5 py-3 text-gray-400">
        <p class="text-3xl">☝️</p>
        <p class="text-sm font-medium text-gray-500">請點選上方拼音字母</p>
        <p class="text-xs">Nhấn vào ký hiệu phiên âm phía trên</p>
      </div>
      <div id="if-detail" style="display:none" class="flex gap-3 items-center">
        <div class="flex flex-col items-center gap-1 flex-shrink-0">
          <p id="ifd-letter" class="text-4xl font-black text-sky-600 leading-none"></p>
          <p id="ifd-vn"     class="text-xs text-gray-400 text-center leading-tight"></p>
        </div>
        <div class="w-px self-stretch bg-gray-200"></div>
        <img id="ifd-img" src="" alt="" class="w-16 h-16 object-contain rounded-2xl bg-gray-50 border border-gray-100 flex-shrink-0" />
        <div class="flex-1 min-w-0">
          <p id="ifd-word" class="text-lg font-bold text-gray-800 leading-tight"></p>
          <p id="ifd-pinyin" class="text-sm font-medium text-sky-600"></p>
          <p id="ifd-trans" class="text-xs text-gray-500"></p>
        </div>
        <button onclick="window.playCurrentIF()" class="w-10 h-10 bg-sky-500 hover:bg-sky-600 rounded-full flex items-center justify-center flex-shrink-0 transition-colors shadow">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="white"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- ── Tab 3: 練習① ─────────────────────────────────────────── -->
  <section id="sec-quiz1" class="tab-section hidden">
    <div id="q1-score-bar" class="flex items-center gap-3 px-4 py-3 bg-white/90 backdrop-blur sticky top-[84px] z-10 border-b border-gray-100">
      <div class="flex-1 h-2 bg-gray-200 rounded-full overflow-hidden">
        <div id="q1-progress" class="h-2 bg-teal-500 rounded-full transition-all" style="width:0%"></div>
      </div>
      <span id="q1-score-text" class="text-xs font-bold text-gray-500 flex-shrink-0">0 / 10</span>
    </div>
    <div id="quiz1-list" class="px-4 py-4 space-y-4 pb-8"></div>
    <div id="q1-summary" style="display:none" class="px-4 py-8 text-center">
      <p class="text-4xl mb-2">🎉</p>
      <p class="text-xl font-bold text-gray-800">Hoàn thành!</p>
      <p id="q1-final-score" class="text-lg text-teal-600 font-bold mt-1"></p>
      <button onclick="resetQuiz(1)" class="mt-4 px-6 py-2 bg-teal-500 text-white rounded-xl text-sm font-bold">Làm lại / 重新作答</button>
    </div>
  </section>

  <!-- ── Tab 4: 拼音練習 ───────────────────────────────────────── -->
  <section id="sec-practical" class="tab-section hidden">
    <div class="relative w-full bg-gray-200 overflow-hidden" style="height:55vw; max-height:46vh">
      <img src={`${BASE}/images/L0_scene.png`} alt="拼音練習場景" class="w-full h-full object-cover" />
      <div id="hotspot-container"></div>
    </div>
    <div id="practical-detail" class="px-4 py-4">
      <div id="prac-empty" class="flex flex-col items-center gap-2 py-6 text-gray-400">
        <p class="text-3xl">👆</p>
        <p class="text-sm font-medium text-gray-500">點擊圖片上的按鈕</p>
        <p class="text-xs">Nhấn vào các nút trên hình ảnh</p>
      </div>
      <div id="prac-word" style="display:none" class="flex items-center gap-4 bg-teal-50 rounded-2xl px-5 py-4">
        <img id="prac-img" src="" alt="" class="w-16 h-16 object-contain rounded-2xl bg-white border border-teal-100 flex-shrink-0" />
        <div class="flex-1 min-w-0">
          <p id="prac-zh"     class="text-2xl font-bold text-gray-800 leading-tight"></p>
          <p id="prac-pinyin" class="text-base font-medium text-teal-600"></p>
          <p id="prac-vn"     class="text-sm text-gray-500"></p>
        </div>
        <button onclick="window.playCurrentPrac()" class="w-12 h-12 bg-teal-500 hover:bg-teal-600 rounded-full flex items-center justify-center flex-shrink-0 transition-colors shadow-md">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="white"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- ── Tab 5: 延伸學習 ───────────────────────────────────────── -->
  <section id="sec-extended" class="tab-section hidden -mx-4">
    <div class="px-4 py-3 border-b border-gray-100">
      <p class="text-sm font-bold text-gray-700">日常回應語 <span class="font-normal text-xs text-gray-400">Câu trả lời thông thường</span></p>
    </div>
    <div id="extended-list" class="px-4 py-4 space-y-4 pb-8"></div>
  </section>

  <!-- ── Tab 6: 練習② ─────────────────────────────────────────── -->
  <section id="sec-quiz2" class="tab-section hidden">
    <div id="q2-score-bar" class="flex items-center gap-3 px-4 py-3 bg-white/90 backdrop-blur sticky top-[84px] z-10 border-b border-gray-100">
      <div class="flex-1 h-2 bg-gray-200 rounded-full overflow-hidden">
        <div id="q2-progress" class="h-2 bg-teal-500 rounded-full transition-all" style="width:0%"></div>
      </div>
      <span id="q2-score-text" class="text-xs font-bold text-gray-500 flex-shrink-0">0 / 5</span>
    </div>
    <div id="quiz2-list" class="px-4 py-4 space-y-4 pb-8"></div>
    <div id="q2-summary" style="display:none" class="px-4 py-8 text-center">
      <p class="text-4xl mb-2">🎉</p>
      <p class="text-xl font-bold text-gray-800">Hoàn thành!</p>
      <p id="q2-final-score" class="text-lg text-teal-600 font-bold mt-1"></p>
      <button onclick="resetQuiz(2)" class="mt-4 px-6 py-2 bg-teal-500 text-white rounded-xl text-sm font-bold">Làm lại / 重新作答</button>
    </div>
  </section>
  </div><!-- /max-w-md -->

<style>
  :global(.flip-card) { perspective: 800px; }
  :global(.flip-card-inner) {
    position: relative; width: 100%; height: 100%;
    transition: transform 0.45s ease;
    transform-style: preserve-3d;
  }
  :global(.flip-card.flipped .flip-card-inner) { transform: rotateY(180deg); }
  :global(.flip-card-front), :global(.flip-card-back) {
    position: absolute; inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }
  :global(.flip-card-back) { transform: rotateY(180deg); }
  :global(.hotspot-btn) {
    position: absolute;
    transform: translate(-50%, -50%);
    width: 40px; height: 40px;
    border-radius: 50%;
    background: rgba(13,148,136,0.9);
    color: white;
    font-size: 10px; font-weight: bold;
    border: 2px solid white;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    animation: pulse-dot 2s infinite;
    box-shadow: 0 0 0 0 rgba(13,148,136,0.5);
    line-height: 1.1; text-align: center;
    white-space: nowrap;
  }
  :global(.hotspot-btn.active) { background: rgba(5,95,85,0.95); box-shadow: 0 0 0 4px rgba(13,148,136,0.3); }
  @keyframes pulse-dot {
    0%   { box-shadow: 0 0 0 0 rgba(13,148,136,0.5); }
    70%  { box-shadow: 0 0 0 10px rgba(13,148,136,0); }
    100% { box-shadow: 0 0 0 0 rgba(13,148,136,0); }
  }
</style>

<script define:vars={{ BASE }}>
const audio = document.getElementById('global-audio');

window.playAudio = function(file) {
  audio.src = BASE + '/audio/' + file;
  audio.currentTime = 0;
  audio.play().catch(() => {});
};

// ════════════════════════════════════════
// DATA
// ════════════════════════════════════════

const TONES = [
  { id:1, name:'第一聲', vn:'Thanh 1 · Thanh thứ nhất', mark:'－', char:'mā', desc:'Giọng cao, đều',        word:'媽媽', pinyin:'mā ma',   trans:'Mẹ (người nhà)',     toneImg:'L0_tone1.png', exImg:'L0_37.png', audio:'L0_37.wav' },
  { id:2, name:'第二聲', vn:'Thanh 2 · Thanh thứ hai',  mark:'ˊ',  char:'má', desc:'Giọng lên cao',        word:'腳麻', pinyin:'jiǎo má',  trans:'Tê chân',            toneImg:'L0_tone2.png', exImg:'L0_38.png', audio:'L0_38.wav' },
  { id:3, name:'第三聲', vn:'Thanh 3 · Thanh thứ ba',   mark:'ˇ',  char:'mǎ', desc:'Giọng xuống rồi lên', word:'馬桶', pinyin:'mǎ tǒng',  trans:'Bồn cầu',            toneImg:'L0_tone3.png', exImg:'L0_39.png', audio:'L0_39.wav' },
  { id:4, name:'第四聲', vn:'Thanh 4 · Thanh thứ tư',   mark:'ˋ',  char:'mà', desc:'Giọng hạ thấp nhanh', word:'罵人', pinyin:'mà rén',   trans:'Mắng / La rầy',     toneImg:'L0_tone4.png', exImg:'L0_40.png', audio:'L0_40.wav' },
  { id:5, name:'輕聲',   vn:'Thanh nhẹ',                mark:'·',  char:'ma', desc:'Giọng nhẹ và ngắn',   word:'痛嗎', pinyin:'tòng ma',  trans:'(Có) đau không?',   toneImg:'L0_tone5.png', exImg:'L0_41.png', audio:'L0_41.wav' },
];

const INITIALS = [
  { pinyin:'b',  group:'b / p',            vn:'pơ',              word:'幫忙', wp:'bāng máng', trans:'Giúp đỡ',                  img:'L0_01.png', audio:'L0_01.wav' },
  { pinyin:'p',  group:'b / p',            vn:'pơ (bật hơi)',    word:'拍背', wp:'pāi bèi',   trans:'Vỗ lưng',                  img:'L0_02.png', audio:'L0_02.wav' },
  { pinyin:'m',  group:'m / f',            vn:'mơ',              word:'毛巾', wp:'máo jīn',   trans:'Khăn mặt / Khăn tắm',      img:'L0_03.png', audio:'L0_03.wav' },
  { pinyin:'f',  group:'m / f',            vn:'phơ',             word:'復健', wp:'fù jiàn',   trans:'Phục hồi chức năng',       img:'L0_04.png', audio:'L0_04.wav' },
  { pinyin:'d',  group:'d / t',            vn:'tơ',              word:'打針', wp:'dǎ zhēn',   trans:'Tiêm / Chích',             img:'L0_05.png', audio:'L0_05.wav' },
  { pinyin:'t',  group:'d / t',            vn:'thơ (bật hơi)',   word:'痛',   wp:'tòng',      trans:'Đau',                      img:'L0_06.png', audio:'L0_06.wav' },
  { pinyin:'n',  group:'n / l',            vn:'nơ',              word:'拿',   wp:'ná',        trans:'Lấy / Cầm',                img:'L0_07.png', audio:'L0_07.wav' },
  { pinyin:'l',  group:'n / l',            vn:'lơ',              word:'輪椅', wp:'lún yǐ',    trans:'Xe lăn',                   img:'L0_08.png', audio:'L0_08.wav' },
  { pinyin:'g',  group:'g / k / h',        vn:'cơ',              word:'阿公', wp:'ā gōng',    trans:'Ông',                      img:'L0_09.png', audio:'L0_09.wav' },
