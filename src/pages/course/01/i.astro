  { zh:'阿嬤',   py:'ā mà',        vi:'Bà / bà nội',            wav:'L1_21.wav' },
  { zh:'護理長', py:'hù lǐ zhǎng', vi:'Trưởng điều dưỡng',      wav:'L1_22.wav' },
  { zh:'早安',   py:'zǎo ān',      vi:'Chào buổi sáng',         wav:'L1_23.wav' },
  { zh:'謝謝',   py:'xièxie',      vi:'Cảm ơn',                 wav:'L1_24.wav' },
  { zh:'不客氣', py:'bú kèqi',     vi:'Không có gì',            wav:'L1_25.wav' },
  { zh:'請問',   py:'qǐngwèn',     vi:'Xin hỏi',                wav:'L1_26.wav' },
];

const ext2 = [
  { cat:0, zh:'午安',    py:'wǔ ān',        vi:'Chào buổi trưa',         wav:'L1_27.wav' },
  { cat:0, zh:'晚安',    py:'wǎn ān',       vi:'Chúc ngủ ngon',          wav:'L1_28.wav' },
  { cat:0, zh:'再見',    py:'zàijiàn',      vi:'Tạm biệt',               wav:'L1_29.wav' },
