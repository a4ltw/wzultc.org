];

const sentences = [
  { zh:'我叫（名字）。',                   py:'Wǒ jiào (míngzi).',                                      vi:'Tôi tên là (tên).',                                wav:'L1_12.wav' },
  { zh:'我是（國家）人。\n我是越南人。',   py:'Wǒ shì (guójiā) rén.\nWǒ shì Yuènán rén.',             vi:'Tôi là người (quốc gia).\nTôi là người Việt Nam.', wav:'L1_13.wav' },
  { zh:'你是照護員嗎？',                   py:'Nǐ shì zhàohùyuán ma?',                                  vi:'Bạn là nhân viên chăm sóc à?',                     wav:'L1_14.wav' },
  { zh:'很高興認識你！',                   py:'Hěn gāoxìng rènshì nǐ!',                                 vi:'Rất vui được gặp bạn!',                             wav:'L1_15.wav' },
];

const dialogueLines = [
  { role:'美玲', side:'left',  zh:'你好！請問你叫什麼名字？',           py:'Nǐ hǎo! Qǐngwèn nǐ jiào shénme míngzi?', vi:'Xin chào! Xin hỏi, bạn tên là gì?',                wav:'L1_16.wav' },
  { role:'蘭',   side:'right', zh:'我叫蘭。我是越南人。你呢？',         py:'Wǒ jiào Lán. Wǒ shì Yuènán rén. Nǐ ne?', vi:'Tôi tên là Lan. Tôi là người Việt Nam. Còn bạn?',  wav:'L1_17.wav' },
  { role:'美玲', side:'left',  zh:'我叫美玲，我是照護員。',              py:'Wǒ jiào Měilíng, wǒ shì zhàohùyuán.',     vi:'Tôi tên là Mỹ Linh, tôi là nhân viên chăm sóc.',   wav:'L1_18.wav' },
  { role:'蘭',   side:'right', zh:'很高興認識你！',                       py:'Hěn gāoxìng rènshì nǐ!',                  vi:'Rất vui được gặp bạn!',                             wav:'L1_19.wav' },
];

const ext1 = [
