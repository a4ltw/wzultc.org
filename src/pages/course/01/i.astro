  { zh:'國家',    py:'guójiā',              vi:'quốc gia',               img:'L1_07.png', wav:'L1_07.wav' },
  { zh:'台灣',    py:'Táiwān',              vi:'Đài Loan',               img:'L1_08.png', wav:'L1_08.wav' },
  { zh:'越南',    py:'Yuènán',              vi:'Việt Nam',               img:'L1_09.png', wav:'L1_09.wav' },
  { zh:'照護員',  py:'zhàohùyuán',          vi:'nhân viên chăm sóc',     img:'L1_10.png', wav:'L1_10.wav' },
