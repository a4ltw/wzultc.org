  { cat:4, zh:'加油',    py:'jiā yóu',      vi:'Cố lên!',                wav:'L1_46.wav' },
];

const videoQuizzes = [
  {
    time: 3,
    q: 'Khi người trong video nói "請問你叫什麼名字？(Qǐngwèn nǐ jiào shénme míngzi?)", cô ấy có ý gì?',
    opts: ['Xin hỏi, bạn tên là gì?', 'Xin hỏi, bạn bao nhiêu tuổi?', 'Xin hỏi, bạn là người nước nào?'],
