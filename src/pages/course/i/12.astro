      { role:'蘭→阿公', zh:'不要動！',       py:'Bú yào dòng!',           vi:'Đừng cử động!',       wav:'L12_28.wav' },
      { role:'蘭→美玲', zh:'他跌倒了。',     py:'Tā diédǎo le.',          vi:'Ông ấy bị té rồi.',   wav:'L12_29.wav' },
      { role:'蘭→美玲', zh:'傷口流血了。',   py:'Shāngkǒu liú xiě le.',   vi:'Vết thương đang chảy máu.', wav:'L12_30.wav' },
      { role:'美玲→蘭', zh:'快打電話！',     py:'Kuài dǎ diànhuà!',       vi:'Mau gọi điện!',       wav:'L12_31.wav' },
      { role:'美玲→蘭', zh:'送急診！',       py:'Sòng jízhěn!',           vi:'Đưa vào cấp cứu!',    wav:'L12_32.wav' },
