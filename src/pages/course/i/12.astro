      { role:'蘭→爸爸', zh:'您好，我是照護員。', py:'Nín hǎo, wǒ shì zhàohùyuán.',   vi:'Chào anh/chị, tôi là nhân viên chăm sóc.', wav:'L12_34.wav' },
      { role:'爸爸→蘭', zh:'他現在怎麼樣？',     py:'Tā xiànzài zěnme yàng?',         vi:'Bây giờ ông ấy thế nào?',                  wav:'L12_35.wav' },
      { role:'蘭→爸爸', zh:'醫生來看過。',       py:'Yīshēng lái kàn guò.',           vi:'Bác sĩ đã đến khám.',                       wav:'L12_36.wav' },
      { role:'蘭→爸爸', zh:'他已經醒了。',       py:'Tā yǐjīng xǐng le.',             vi:'Ông ấy đã tỉnh rồi.',                       wav:'L12_37.wav' },
      { role:'蘭→爸爸', zh:'情況穩定。',         py:'Qíngkuàng wěndìng.',             vi:'Tình trạng ổn định.',                       wav:'L12_38.wav' },
      { role:'阿公→爸爸',zh:'請放心。',          py:'Qǐng fàngxīn.',                  vi:'Xin yên tâm.',                              wav:'L12_39.wav' },
    ],
  },
  {
    id: 5,
    titleZh: '記錄與回報',
    titleVi: 'Ghi chép & báo cáo',
    lines: [
      { role:'蘭→媽媽', zh:'中午十二點半吃飯。', py:"Zhōngwǔ shí'èr diǎn bàn chī fàn.", vi:'Mười hai giờ rưỡi trưa ăn cơm.', wav:'L12_40.wav' },
      { role:'蘭→媽媽', zh:'然後吃藥。',         py:'Ránhòu chī yào.',                  vi:'Sau đó uống thuốc.',              wav:'L12_41.wav' },
      { role:'蘭→媽媽', zh:'下午睡了半個鐘頭。', py:'Xiàwǔ shuì le bàn ge zhōngtóu.',  vi:'Buổi chiều ngủ nửa tiếng.',      wav:'L12_42.wav' },
      { role:'阿嬤→媽媽',zh:'現在不痛了。',      py:'Xiànzài bú tòng le.',              vi:'Bây giờ không còn đau nữa.',     wav:'L12_43.wav' },
      { role:'蘭→媽媽', zh:'都已經記錄了。',     py:'Dōu yǐjīng jìlù le.',             vi:'Tất cả đều đã ghi chép rồi.',    wav:'L12_44.wav' },
      { role:'蘭→媽媽', zh:'我來回報一下。',     py:'Wǒ lái huíbào yíxià.',            vi:'Tôi đến báo cáo một chút.',      wav:'L12_45.wav' },
    ],
  },
];

/* ── AUDIO ── */
const globalAudio = document.getElementById('global-audio');
window.playAudio = function(wav) {
  globalAudio.src = BASE + '/audio/' + wav;
  globalAudio.currentTime = 0;
  globalAudio.play().catch(() => {});
};

/* ── TABS ── */
function switchTab(id) {
  document.querySelectorAll('.tab-section').forEach(s => s.classList.add('hidden'));
  document.getElementById('sec-' + id).classList.remove('hidden');
  document.querySelectorAll('.tab-btn').forEach(b => {
    const on = b.dataset.tab === id;
    b.classList.toggle('opacity-100', on);
    b.classList.toggle('border-white', on);
    b.classList.toggle('opacity-60', !on);
    b.classList.toggle('border-transparent', !on);
  });
}
document.querySelectorAll('.tab-btn').forEach(b => b.addEventListener('click', () => switchTab(b.dataset.tab)));
switchTab('vocab');

/* ── TAB SCROLL ── */
const tabScroll = document.getElementById('tab-scroll');
const tabPrev = document.getElementById('tab-prev');
const tabNext = document.getElementById('tab-next');
const TAB_STEP = 120;
function updateTabNav() {
  const atStart = tabScroll.scrollLeft <= 4;
  const atEnd = tabScroll.scrollLeft + tabScroll.clientWidth >= tabScroll.scrollWidth - 4;
  tabPrev.classList.toggle('hidden', atStart);
  tabNext.classList.toggle('hidden', atEnd);
}
tabPrev.addEventListener('click', () => { tabScroll.scrollBy({ left: -TAB_STEP, behavior: 'smooth' }); });
tabNext.addEventListener('click', () => { tabScroll.scrollBy({ left: TAB_STEP, behavior: 'smooth' }); });
tabScroll.addEventListener('scroll', updateTabNav, { passive: true });
updateTabNav();

/* ── SECTION 1: 生詞 ── */
const vocabButtonsEl = document.getElementById('vocab-buttons');
const vocabDetailEmpty = document.getElementById('vocab-detail-empty');
const vocabDetailContent = document.getElementById('vocab-detail-content');
const vocabDetailVi = document.getElementById('vocab-detail-vi');
const vocabDetailImg = document.getElementById('vocab-detail-img');
const allVocabBtns = [];

vocab.forEach(v => {
  const btn = document.createElement('button');
  const isLong = v.zh.length > 4;
  btn.className = 'w-full flex items-center justify-between py-4 px-5 rounded-2xl border-2 border-slate-200 bg-white shadow-sm transition-all duration-200 active:scale-[0.98]';
  btn.innerHTML = `
    <div class="text-left">
      <div class="vocab-zh ${isLong ? 'text-xl' : 'text-2xl'} font-bold text-gray-800 leading-tight">${v.zh}</div>
      <div class="vocab-py text-sm text-gray-400 mt-0.5" style="font-family:Arial,sans-serif">${v.py}</div>
    </div>
    <span class="text-xl text-gray-300 flex-shrink-0">🔊</span>`;
  btn.addEventListener('click', () => {
    allVocabBtns.forEach(b => {
      b.className = 'w-full flex items-center justify-between py-4 px-5 rounded-2xl border-2 border-slate-200 bg-white shadow-sm transition-all duration-200 active:scale-[0.98]';
      b.querySelector('.vocab-zh').style.color = '';
      b.querySelector('.vocab-py').style.color = '';
    });
    btn.className = 'w-full flex items-center justify-between py-4 px-5 rounded-2xl border-2 border-rose-500 bg-rose-500 shadow-lg ring-4 ring-rose-100 transition-all duration-200 active:scale-[0.98]';
    btn.querySelector('.vocab-zh').style.color = 'white';
    btn.querySelector('.vocab-py').style.color = 'rgb(253 164 175)';
    window.playAudio(v.wav);
    vocabDetailEmpty.style.display = 'none';
    vocabDetailContent.style.display = 'flex';
    vocabDetailVi.textContent = v.vi;
    vocabDetailImg.src = BASE + '/images/' + v.img;
    vocabDetailImg.alt = v.zh;
  });
  allVocabBtns.push(btn);
  vocabButtonsEl.appendChild(btn);
});

/* ── SECTION 2: 句型練習 ── */
const sentenceChat = document.getElementById('sentence-chat');
const sentenceBtns = document.getElementById('sentence-btns');
sentences.forEach(s => {
  const btn = document.createElement('button');
  btn.className = 'w-full bg-gray-50 hover:bg-blue-50 border border-gray-200 text-left px-4 py-3 rounded-xl transition-colors flex items-center justify-between active:scale-[0.98]';
  btn.innerHTML = `<span class="text-[#0068ff] font-medium text-base" style="font-family:Arial,sans-serif">${s.py}</span><span class="text-gray-300 text-sm flex-shrink-0">▶</span>`;
  btn.addEventListener('click', () => {
    window.playAudio(s.wav);
    const bubble = document.createElement('div');
    bubble.className = 'flex justify-end w-full';
    bubble.innerHTML = `
      <div class="bg-[#e5efff] rounded-2xl rounded-tr-none p-3 max-w-[85%] shadow-sm border border-blue-100">
        <div class="flex justify-between items-start gap-3 mb-1">
          <div class="text-lg font-bold text-gray-800 tracking-wide whitespace-pre-line">${s.zh}</div>
          <button onclick="window.playAudio('${s.wav}')" class="w-8 h-8 rounded-full bg-blue-100 hover:bg-[#0068ff] hover:text-white text-[#0068ff] flex items-center justify-center flex-shrink-0 transition-colors text-sm">🔊</button>
        </div>
        <div class="text-[#0068ff] text-sm font-medium mb-2" style="font-family:Arial,sans-serif">${s.py}</div>
        <div class="text-gray-600 text-sm border-t border-blue-200/60 pt-2">${s.vi}</div>
      </div>`;
    sentenceChat.appendChild(bubble);
    sentenceChat.scrollTop = sentenceChat.scrollHeight;
  });
  sentenceBtns.appendChild(btn);
});

/* ── SECTION 3–7: 情境任務 ── */
if (!document.getElementById('task-pulse-style')) {
  const ps = document.createElement('style');
  ps.id = 'task-pulse-style';
  ps.textContent = '@keyframes task-pulse{0%{box-shadow:0 0 0 0 rgba(239,68,68,0.5)}70%{box-shadow:0 0 0 8px rgba(239,68,68,0)}100%{box-shadow:0 0 0 0 rgba(239,68,68,0)}}';
  document.head.appendChild(ps);
}

const taskHotspots = [
  { idx:0, x: 5, y: 9 },
  { idx:1, x:36, y: 9 },
  { idx:2, x:73, y: 9 },
  { idx:3, x:26, y:59 },
  { idx:4, x:61, y:59 },
  { idx:5, x:93, y:59 },
];

tasks.forEach(task => {
  const titleEl = document.getElementById(`task${task.id}-title`);
  if (titleEl) titleEl.innerHTML = `情境任務 ${task.id}：${task.titleZh} <span class="font-normal text-sm text-gray-400">${task.titleVi}</span>`;

  const grid = document.getElementById(`task${task.id}-grid`);
  const map = document.getElementById(`task${task.id}-map`);

  task.lines.forEach((line, i) => {
    const roleColors = ['bg-blue-600','bg-rose-500','bg-purple-600','bg-teal-600','bg-orange-500','bg-indigo-600'];
    const roleColor = roleColors[i % roleColors.length];
    const card = document.createElement('div');
    card.className = 'bg-white rounded-2xl shadow-sm border border-gray-200 p-4 cursor-pointer transition-all active:scale-[0.98]';
    card.innerHTML = `
      <div class="flex justify-between items-start mb-2">
        <div class="flex items-center gap-2">
          <span class="w-6 h-6 rounded-full bg-orange-100 text-orange-700 text-xs font-bold flex items-center justify-center flex-shrink-0">${i+1}</span>
          <span class="px-3 py-1 rounded-full text-xs font-bold text-white ${roleColor}">${line.role}</span>
        </div>
        <button onclick="event.stopPropagation(); window.playAudio('${line.wav}')" class="text-rose-600 bg-rose-50 hover:bg-rose-100 rounded-full w-8 h-8 flex items-center justify-center transition-colors text-sm">🔊</button>
      </div>
      <div class="text-xl font-bold text-gray-800 tracking-wide mb-1">${line.zh}</div>
      <div class="text-base text-rose-700 font-medium mb-2" style="font-family:Arial,sans-serif">${line.py}</div>
      <div class="text-sm text-gray-500 border-t border-gray-100 pt-2 flex items-start gap-2">
        <span class="text-xs bg-gray-100 text-gray-400 px-1.5 py-0.5 rounded mt-0.5 flex-shrink-0">VN</span>
        <span>${line.vi}</span>
      </div>`;
    card.addEventListener('click', () => window.playAudio(line.wav));
    grid.appendChild(card);
  });

  taskHotspots.forEach(({ idx, x, y }) => {
    if (idx >= task.lines.length) return;
    const h = document.createElement('button');
    h.title = `${idx+1}. ${task.lines[idx].zh}`;
    h.style.cssText = `position:absolute;left:${x}%;top:${y}%;width:24px;height:24px;border-radius:50%;background:rgba(239,68,68,0.92);border:2px solid white;transform:translate(-50%,-50%);cursor:pointer;animation:task-pulse 2s infinite;`;
    h.addEventListener('click', () => {
      const card = grid.children[idx];
      if (!card) return;
      card.scrollIntoView({ behavior:'smooth', block:'nearest' });
      window.playAudio(task.lines[idx].wav);
      card.style.outline = '3px solid #e11d48';
      card.style.outlineOffset = '3px';
      setTimeout(() => { card.style.outline=''; card.style.outlineOffset=''; }, 1500);
    });
    map.appendChild(h);
  });
});

/* ── 校正模式 ── */
if (new URLSearchParams(location.search).has('calibrate')) {
  const taskN = parseInt(new URLSearchParams(location.search).get('task') || '1');
  switchTab('task' + taskN);
  const imgWrap = document.getElementById(`task${taskN}-map`);
  const banner = document.createElement('div');
  banner.style.cssText = 'position:fixed;top:56px;left:0;right:0;background:#f59e0b;color:#000;text-align:center;padding:8px 16px;font-weight:bold;z-index:9999;font-size:13px;';
  banner.textContent = `🎯 校正模式｜情境任務 ${taskN}，點圖片位置 → 下方顯示座標`;
  document.body.appendChild(banner);
  const display = document.createElement('div');
  display.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#1e293b;color:#fff;padding:14px 28px;border-radius:16px;font-size:20px;font-family:monospace;z-index:9999;display:none;text-align:center;min-width:160px;';
  document.body.appendChild(display);
  if (imgWrap) {
    imgWrap.style.cursor = 'crosshair';
    imgWrap.addEventListener('click', e => {
      const r = imgWrap.getBoundingClientRect();
      const x = Math.round((e.clientX - r.left) / r.width * 100);
      const y = Math.round((e.clientY - r.top) / r.height * 100);
      display.style.display = 'block';
      display.innerHTML = 'x: <b>' + x + '</b>，y: <b>' + y + '</b>';
      display.style.background = '#059669';
      setTimeout(() => { display.style.background = '#1e293b'; }, 700);
    });
  }
}

</script>

</Layout>
