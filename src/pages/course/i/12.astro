---
import Layout from '../../../layouts/Layout.astro';
const BASE = '/assets/course/l12';
---

<Layout title="第十二課：整合情境實務演練 - WZULTC 台越照護華語" description="台越照護華語第十二課互動練習，包含生詞、句型、五大情境任務實務演練。">

<div class="bg-rose-50 min-h-screen pb-24">

  <!-- Header -->
  <header class="bg-rose-600 text-white shadow-lg sticky top-0 z-30">
    <div class="max-w-3xl mx-auto flex items-center justify-between gap-2 px-3 py-2.5">
      <a href="/course" class="flex flex-col items-center text-xs font-medium bg-white/15 hover:bg-white/25 rounded-lg px-2.5 py-1.5 transition-colors flex-shrink-0">
        <span class="flex items-center gap-1">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
          課程列表
        </span>
        <span class="text-[10px] opacity-70 font-normal">Danh sách</span>
      </a>
      <div class="text-center min-w-0">
        <p class="text-sm font-bold leading-tight">第十二課：整合情境實務演練</p>
        <p class="text-xs opacity-60 mt-0.5">Bài 12: Thực hành tình huống tổng hợp</p>
      </div>
      <a href="/course/12" class="flex flex-col items-center text-xs font-medium bg-white/15 hover:bg-white/25 rounded-lg px-2.5 py-1.5 transition-colors flex-shrink-0">
        <span class="flex items-center gap-1">
          課程簡報
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
        </span>
        <span class="text-[10px] opacity-70 font-normal">Bài giảng</span>
      </a>
    </div>
    <div class="max-w-3xl mx-auto relative flex items-stretch">
      <button id="tab-prev" class="hidden flex-shrink-0 px-2 bg-rose-600 border-t border-white/20 text-white text-lg font-bold hover:bg-rose-500 transition-colors">‹</button>
      <div id="tab-scroll" class="overflow-x-auto scrollbar-none flex-1">
        <div class="flex border-t border-white/20 min-w-max md:min-w-0 md:w-full">
          {[
            ['vocab',    '生詞',  'Từ vựng'],
            ['sentence', '句型',  'Câu mẫu'],
            ['task1',    '情境1', 'TH 1'],
            ['task2',    '情境2', 'TH 2'],
            ['task3',    '情境3', 'TH 3'],
            ['task4',    '情境4', 'TH 4'],
            ['task5',    '情境5', 'TH 5'],
          ].map(([id, zh, vi]) => (
            <button
              class="tab-btn px-4 py-1.5 text-xs font-medium opacity-60 border-b-2 border-transparent transition-all text-center"
              data-tab={id}
            >
              <div class="whitespace-nowrap">{zh}</div>
              <div class="text-[10px] font-normal opacity-70 whitespace-nowrap">{vi}</div>
            </button>
          ))}
        </div>
      </div>
      <button id="tab-next" class="flex-shrink-0 px-2 bg-rose-600 border-t border-white/20 text-white text-lg font-bold hover:bg-rose-500 transition-colors">›</button>
    </div>
  </header>

  <main class="max-w-3xl mx-auto px-4 pt-4 space-y-0">

    <!-- ===== SECTION 1: 生詞 ===== -->
    <section id="sec-vocab" class="tab-section -mx-4 md:mx-0">
      <div class="md:flex md:gap-6 md:items-start">
      <div id="vocab-buttons" class="overflow-y-auto px-4 pt-4 pb-3 space-y-2 max-h-[54vh] md:max-h-none md:flex-1"></div>
      <div class="sticky bottom-0 md:bottom-auto md:top-24 bg-white rounded-t-3xl md:rounded-2xl shadow-[0_-4px_20px_rgba(0,0,0,0.08)] md:shadow-sm border-t md:border border-gray-100 px-5 py-5 z-20 md:z-10 md:w-72 md:flex-shrink-0 md:mt-4">
        <div id="vocab-detail-empty" class="flex flex-col items-center gap-2 py-3 text-gray-400">
          <p class="text-sm font-medium text-gray-500">請點選生詞</p>
          <p class="text-xs">Nhấn vào từ vựng</p>
        </div>
        <div id="vocab-detail-content" style="display:none;" class="flex flex-col items-center gap-3">
          <span class="text-xs font-semibold text-rose-600 bg-rose-50 px-3 py-1 rounded-full">Tiếng Việt (越南文)</span>
          <p id="vocab-detail-vi" class="text-2xl font-bold text-rose-800 text-center leading-tight"></p>
          <img id="vocab-detail-img" src="" alt="" class="w-36 h-36 object-contain rounded-2xl bg-gray-50 border border-gray-100" />
        </div>
      </div>
      </div>
    </section>

    <!-- ===== SECTION 2: 句型練習 ===== -->
    <section id="sec-sentence" class="tab-section hidden -mx-4 md:mx-0 md:rounded-2xl md:overflow-hidden">
      <div class="flex flex-col" style="height:calc(100dvh - 8rem);">
        <div id="sentence-chat" class="flex-1 overflow-y-auto px-4 py-4 space-y-4 bg-[#e2e6f2]">
          <div class="flex justify-center">
            <span class="bg-black/20 text-white text-xs px-3 py-1 rounded-full">點擊下方拼音，開始練習 / Nhấn pinyin để bắt đầu</span>
          </div>
        </div>
        <div class="bg-white border-t border-gray-200 px-4 pt-3 pb-4 shadow-[0_-3px_10px_rgba(0,0,0,0.05)] flex-shrink-0">
          <p class="text-xs text-gray-400 mb-2">👇 請點擊拼音來發送句子：</p>
          <div id="sentence-btns" class="space-y-2 overflow-y-auto" style="max-height:32vh;"></div>
        </div>
      </div>
    </section>

    <!-- ===== SECTION 3–7: 情境任務 1–5 ===== -->
    {[1,2,3,4,5].map(n => (
      <section id={`sec-task${n}`} class="tab-section hidden space-y-3">
        <div class="bg-white rounded-2xl p-4 shadow-sm border-l-4 border-orange-500">
          <h2 class="font-bold text-orange-800 mb-1" id={`task${n}-title`}>情境任務 {n}</h2>
          <p class="text-xs text-gray-400">點圖上紅點跳字卡・翻卡看越南文・點 ▶ 聽發音</p>
        </div>
        <div class="bg-white rounded-2xl p-4 shadow-sm">
          <div id={`task${n}-map`} class="relative rounded-xl overflow-hidden mb-4">
            <img src={`${BASE}/images/L12_task${n}.png`} alt={`情境任務${n}插圖`} class="w-full h-auto block" loading="lazy" />
          </div>
        </div>
        <div id={`task${n}-grid`} class="grid grid-cols-1 md:grid-cols-2 gap-3"></div>
      </section>
    ))}

  </main>
</div>

<audio id="global-audio"></audio>

<style>
  .scrollbar-none::-webkit-scrollbar { display: none; }
  .scrollbar-none { -ms-overflow-style: none; scrollbar-width: none; }
  :global(.flip-card) { perspective: 800px; }
  :global(.flip-card-inner) { position: relative; width: 100%; height: 100%; transition: transform 0.45s ease; transform-style: preserve-3d; }
  :global(.flip-card.flipped .flip-card-inner) { transform: rotateY(180deg); }
  :global(.flip-card-front), :global(.flip-card-back) { position: absolute; inset: 0; backface-visibility: hidden; -webkit-backface-visibility: hidden; }
  :global(.flip-card-back) { transform: rotateY(180deg); }
</style>

<script is:inline define:vars={{ BASE }}>

const vocab = [
  { zh:'情境', py:'qíngjìng', vi:'tình huống',  img:'L12_01.png', wav:'L12_01.wav' },
  { zh:'練習', py:'liànxí',   vi:'luyện tập',    img:'L12_02.png', wav:'L12_02.wav' },
  { zh:'回顧', py:'huígù',    vi:'ôn lại',        img:'L12_03.png', wav:'L12_03.wav' },
  { zh:'說明', py:'shuōmíng', vi:'giải thích',   img:'L12_04.png', wav:'L12_04.wav' },
  { zh:'安撫', py:'ānfǔ',     vi:'trấn an',       img:'L12_05.png', wav:'L12_05.wav' },
  { zh:'回報', py:'huíbào',   vi:'báo cáo',       img:'L12_06.png', wav:'L12_06.wav' },
  { zh:'照護', py:'zhàohù',   vi:'chăm sóc',      img:'L12_07.png', wav:'L12_07.wav' },
  { zh:'溝通', py:'gōutōng',  vi:'giao tiếp',     img:'L12_08.png', wav:'L12_08.wav' },
  { zh:'配合', py:'pèihé',    vi:'phối hợp',      img:'L12_09.png', wav:'L12_09.wav' },
  { zh:'完成', py:'wánchéng', vi:'hoàn thành',    img:'L12_10.png', wav:'L12_10.wav' },
];

const sentences = [
  { zh:'哪裡不舒服？',         py:'Nǎlǐ bù shūfu?',               vi:'Khó chịu ở đâu?',                wav:'L12_11.wav' },
  { zh:'請放心，我會照顧。',   py:'Qǐng fàngxīn, wǒ huì zhàogù.', vi:'Xin yên tâm, tôi sẽ chăm sóc.', wav:'L12_12.wav' },
  { zh:'不要動，我幫你。',     py:'Bú yào dòng, wǒ bāng nǐ.',     vi:'Đừng cử động, tôi giúp bạn.',    wav:'L12_13.wav' },
  { zh:'我來回報一下。',       py:'Wǒ lái huíbào yíxià.',          vi:'Tôi đến báo cáo một chút.',       wav:'L12_14.wav' },
  { zh:'已經記錄了。',         py:'Yǐjīng jìlù le.',               vi:'Đã ghi chép rồi.',                wav:'L12_15.wav' },
];

const tasks = [
  {
    id: 1,
    titleZh: '日常照護＋安撫',
    titleVi: 'Chăm sóc hằng ngày & trấn an',
    lines: [
      { role:'蘭',   zh:'哪裡不舒服？',     py:'Nǎlǐ bù shūfu?',                   vi:'Bạn khó chịu ở đâu?',             wav:'L12_16.wav' },
      { role:'阿嬤', zh:'有一點頭痛。',     py:'Yǒu yìdiǎn tóu tòng.',             vi:'Tôi hơi đau đầu.',                wav:'L12_17.wav' },
      { role:'蘭',   zh:'不要怕，我陪你。', py:'Bú yào pà, wǒ péi nǐ.',            vi:'Đừng sợ, tôi ở bên bạn.',         wav:'L12_18.wav' },
      { role:'蘭',   zh:'慢慢來，先坐一下。',py:'Mànmàn lái, xiān zuò yíxià.',     vi:'Từ từ thôi, ngồi xuống trước.',   wav:'L12_19.wav' },
      { role:'蘭',   zh:'要不要喝一點水？', py:'Yào bú yào hē yìdiǎn shuǐ?',      vi:'Có muốn uống chút nước không?',   wav:'L12_20.wav' },
      { role:'阿嬤', zh:'好，謝謝你。',     py:'Hǎo, xièxie nǐ.',                  vi:'Được, cảm ơn bạn.',               wav:'L12_21.wav' },
    ],
  },
  {
    id: 2,
    titleZh: '醫療處置＋說明',
    titleVi: 'Xử lý y tế & giải thích',
    lines: [
      { role:'護士', zh:'每天起床後喝一點溫水。',   py:'Měitiān qǐchuáng hòu hē yìdiǎn wēn shuǐ.', vi:'Mỗi ngày sau khi thức dậy uống một ít nước ấm.', wav:'L12_22.wav' },
      { role:'護士', zh:'下午不要睡太久。',         py:'Xiàwǔ bú yào shuì tài jiǔ.',               vi:'Buổi chiều đừng ngủ quá lâu.',                   wav:'L12_23.wav' },
      { role:'護士', zh:'高血壓藥每天吃一顆。',     py:'Gāo xuèyā yào měitiān chī yì kē.',         vi:'Thuốc cao huyết áp mỗi ngày uống một viên.',     wav:'L12_24.wav' },
      { role:'護士', zh:'等醫生來看過再說。',       py:'Děng yīshēng lái kàn guò zài shuō.',       vi:'Đợi bác sĩ đến khám rồi hãy nói tiếp.',          wav:'L12_25.wav' },
      { role:'醫生', zh:'現在情況穩定。',           py:'Xiànzài qíngkuàng wěndìng.',               vi:'Hiện tại tình trạng ổn định.',                   wav:'L12_26.wav' },
      { role:'蘭',   zh:'我知道了。',               py:'Wǒ zhīdào le.',                             vi:'Tôi biết rồi.',                                   wav:'L12_27.wav' },
    ],
  },
  {
    id: 3,
    titleZh: '緊急狀況',
