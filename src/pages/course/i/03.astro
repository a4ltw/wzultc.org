  const btn = document.createElement('button');
  const isLong = v.zh.length > 4;
  btn.className = 'w-full flex items-center justify-between py-4 px-5 rounded-2xl border-2 border-slate-200 bg-white shadow-sm transition-all duration-200 active:scale-[0.98]';
  btn.innerHTML = `
    <div class="text-left">
      <div class="vocab-zh ${isLong ? 'text-xl' : 'text-2xl'} font-bold text-gray-800 leading-tight">${v.zh}</div>
      <div class="vocab-py text-sm text-gray-400 mt-0.5" style="font-family:Arial,sans-serif">${v.py}</div>
    </div>
    <span class="text-xl text-gray-300 flex-shrink-0">🔊</span>`;
  btn.addEventListener('click', () => {
    allVocabBtns.forEach(b => {
      b.className = 'w-full flex items-center justify-between py-4 px-5 rounded-2xl border-2 border-slate-200 bg-white shadow-sm transition-all duration-200 active:scale-[0.98]';
      b.querySelector('.vocab-zh').style.color = '';
      b.querySelector('.vocab-py').style.color = '';
    });
    btn.className = 'w-full flex items-center justify-between py-4 px-5 rounded-2xl border-2 border-teal-500 bg-teal-500 shadow-lg ring-4 ring-teal-100 transition-all duration-200 active:scale-[0.98]';
    btn.querySelector('.vocab-zh').style.color = 'white';
    btn.querySelector('.vocab-py').style.color = 'rgb(153 246 228)';
    window.playAudio(v.wav);
    vocabDetailEmpty.style.display = 'none';
    vocabDetailContent.style.display = 'flex';
    vocabDetailVi.textContent = v.vi;
    vocabDetailImg.src = BASE + '/images/' + v.img;
    vocabDetailImg.alt = v.zh;
  });
  allVocabBtns.push(btn);
  vocabButtonsEl.appendChild(btn);
});

/* ── SECTION 2: 句型練習 ── */
const sentenceChat = document.getElementById('sentence-chat');
const sentenceBtns = document.getElementById('sentence-btns');
sentences.forEach(s => {
  const btn = document.createElement('button');
  btn.className = 'w-full bg-gray-50 hover:bg-blue-50 border border-gray-200 text-left px-4 py-3 rounded-xl transition-colors flex items-center justify-between active:scale-[0.98]';
  btn.innerHTML = `<span class="text-[#0068ff] font-medium text-base" style="font-family:Arial,sans-serif">${s.py}</span><span class="text-gray-300 text-sm flex-shrink-0">▶</span>`;
  btn.addEventListener('click', () => {
    window.playAudio(s.wav);
    const bubble = document.createElement('div');
    bubble.className = 'flex justify-end w-full';
    bubble.innerHTML = `
      <div class="bg-[#e5efff] rounded-2xl rounded-tr-none p-3 max-w-[85%] shadow-sm border border-blue-100">
        <div class="flex justify-between items-start gap-3 mb-1">
          <div class="text-lg font-bold text-gray-800 tracking-wide whitespace-pre-line">${s.zh}</div>
          <button onclick="window.playAudio('${s.wav}')" class="w-8 h-8 rounded-full bg-blue-100 hover:bg-[#0068ff] hover:text-white text-[#0068ff] flex items-center justify-center flex-shrink-0 transition-colors text-sm">🔊</button>
        </div>
        <div class="text-[#0068ff] text-sm font-medium mb-2" style="font-family:Arial,sans-serif">${s.py}</div>
        <div class="text-gray-600 text-sm border-t border-blue-200/60 pt-2">${s.vi}</div>
      </div>`;
    sentenceChat.appendChild(bubble);
    sentenceChat.scrollTop = sentenceChat.scrollHeight;
  });
  sentenceBtns.appendChild(btn);
});

/* ── SECTION 3: 影片互動 ── */
const video = document.getElementById('dialogue-video');
const playOverlay = document.getElementById('video-play-overlay');
const playBtn = document.getElementById('video-play-btn');
const quizOverlay = document.getElementById('video-quiz-overlay');
const vqQuestion = document.getElementById('vq-question');
const vqOptions = document.getElementById('vq-options');
const vqFeedback = document.getElementById('vq-feedback');
const vqContinue = document.getElementById('vq-continue');
let vqAnswered = new Set();
let currentVQ = null;

playBtn.addEventListener('click', () => { playOverlay.classList.add('hidden'); video.play(); });
video.addEventListener('play', () => playOverlay.classList.add('hidden'));
video.addEventListener('pause', () => { if (!currentVQ) playOverlay.classList.remove('hidden'); });
video.addEventListener('timeupdate', () => {
  const t = video.currentTime;
  for (const vq of videoQuizzes) {
    if (!vqAnswered.has(vq.time) && t >= vq.time && t < vq.time + 0.5) {
      video.pause(); showVideoQuiz(vq); break;
    }
  }
});

function showVideoQuiz(vq) {
  currentVQ = vq;
  quizOverlay.classList.remove('hidden');
  vqQuestion.textContent = vq.q;
  vqOptions.innerHTML = '';
  vqFeedback.classList.add('hidden');
  vqContinue.classList.add('hidden');
  vq.opts.forEach((opt, i) => {
    const btn = document.createElement('button');
    btn.className = 'w-full text-left px-4 py-2.5 rounded-xl border-2 border-gray-100 hover:border-purple-300 text-sm transition-colors bg-white';
    btn.textContent = String.fromCharCode(65+i) + '. ' + opt;
    btn.addEventListener('click', () => {
      vqOptions.querySelectorAll('button').forEach(b => b.disabled = true);
      if (i === vq.ans) {
        btn.className = 'w-full text-left px-4 py-2.5 rounded-xl border-2 border-green-400 bg-green-50 text-sm text-green-800';
        vqFeedback.textContent = '✓ 正確！Chính xác!';
        vqFeedback.className = 'mt-3 p-3 rounded-xl text-center text-sm font-bold bg-green-100 text-green-700';
      } else {
        btn.className = 'w-full text-left px-4 py-2.5 rounded-xl border-2 border-red-400 bg-red-50 text-sm text-red-800';
        vqOptions.querySelectorAll('button')[vq.ans].className = 'w-full text-left px-4 py-2.5 rounded-xl border-2 border-green-400 bg-green-50 text-sm text-green-800';
        vqFeedback.textContent = '✗ 再試一次。答案是 ' + String.fromCharCode(65+vq.ans) + '. ' + vq.opts[vq.ans];
        vqFeedback.className = 'mt-3 p-3 rounded-xl text-center text-sm font-bold bg-red-100 text-red-700';
      }
      vqFeedback.classList.remove('hidden');
      vqAnswered.add(vq.time);
      vqContinue.classList.remove('hidden');
    });
    vqOptions.appendChild(btn);
  });
}
vqContinue.addEventListener('click', () => { quizOverlay.classList.add('hidden'); currentVQ = null; video.play(); });

/* ── SECTION 4: 情境對話 ── */
const dialogueListEl = document.getElementById('dialogue-list');
dialogueLines.forEach(d => {
  const isLeft = d.side === 'left';
  const speakerColor = isLeft ? 'bg-teal-600' : 'bg-orange-500';
  const card = document.createElement('div');
  card.className = 'bg-white rounded-2xl shadow-sm border border-gray-200 p-4 cursor-pointer transition-all active:scale-[0.98]';
  card.innerHTML = `
    <div class="flex justify-between items-start mb-2">
      <span class="px-3 py-1 rounded-full text-xs font-bold text-white ${speakerColor}">${d.role}</span>
      <button onclick="event.stopPropagation(); window.playAudio('${d.wav}')" class="text-teal-600 bg-teal-50 hover:bg-teal-100 rounded-full w-8 h-8 flex items-center justify-center transition-colors text-sm">🔊</button>
    </div>
    <div class="text-xl font-bold text-gray-800 tracking-wide mb-1">${d.zh}</div>
    <div class="text-base text-teal-700 font-medium mb-2" style="font-family:Arial,sans-serif">${d.py}</div>
    <div class="text-sm text-gray-500 border-t border-gray-100 pt-2 flex items-start gap-2">
      <span class="text-xs bg-gray-100 text-gray-400 px-1.5 py-0.5 rounded mt-0.5 flex-shrink-0">VN</span>
      <span>${d.vi}</span>
    </div>`;
  card.addEventListener('click', () => window.playAudio(d.wav));
  dialogueListEl.appendChild(card);
});

/* ── SECTION 5: 延伸學習1 ── */
const ext1Grid = document.getElementById('ext1-grid');
ext1.forEach(v => ext1Grid.appendChild(makeFlipCard(v.zh, v.py, v.vi, v.wav, 'orange')));

/* ── SECTION 6: 延伸學習2 ── */
let activeCat = 0;
const ext2Grid = document.getElementById('ext2-grid');
function renderExt2(cat) {
  ext2Grid.innerHTML = '';
  ext2.filter(v => v.cat === cat).forEach(v => ext2Grid.appendChild(makeFlipCard(v.zh, v.py, v.vi, v.wav, 'yellow')));
}
document.querySelectorAll('.cat-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    activeCat = parseInt(btn.dataset.cat);
    document.querySelectorAll('.cat-btn').forEach(b => {
      b.classList.toggle('bg-yellow-400', b === btn);
      b.classList.toggle('text-white', b === btn);
      b.classList.toggle('border-yellow-400', b === btn);
      b.classList.toggle('bg-white', b !== btn);
      b.classList.toggle('text-gray-600', b !== btn);
    });
    renderExt2(activeCat);
  });
});
document.querySelectorAll('.cat-btn')[0].click();

</script>

</Layout>
