/* ── SECTION 7: 練習題 ───────────────────────────────────── */
let qIndex = 0;
let qScore = 0;
let qAnswered = false;
const qAudio = new Audio();

function updateScoreBar() {
  document.getElementById('quiz-score').textContent = qScore;
  document.getElementById('quiz-total').textContent = quizData.length;
  document.getElementById('quiz-progress-bar').style.width = (qIndex / quizData.length * 100) + '%';
}

function loadQuestion(i) {
  qAnswered = false;
  const q = quizData[i];
  document.getElementById('quiz-num').textContent = `第 ${i+1} / ${quizData.length} 題`;
  document.getElementById('quiz-question-text').textContent = q.q;
  document.getElementById('quiz-feedback-box').classList.add('hidden');
  document.getElementById('quiz-next-btn').classList.add('hidden');
  document.getElementById('quiz-done').classList.add('hidden');

  const audioPrompt = document.getElementById('quiz-audio-prompt');
  const imagePrompt = document.getElementById('quiz-image-prompt');
  const playBtn2 = document.getElementById('quiz-play-btn');
  audioPrompt.classList.add('hidden');
  imagePrompt.classList.add('hidden');
  if (q.type === 'audio') {
    audioPrompt.classList.remove('hidden');
    qAudio.src = BASE + '/audio/' + q.wav;
    playBtn2.onclick = () => { qAudio.currentTime = 0; qAudio.play(); };
  } else if (q.type === 'image') {
    imagePrompt.classList.remove('hidden');
    document.getElementById('quiz-image').src = BASE + '/images/' + q.img;
  }

  const optList = document.getElementById('quiz-options-list');
  optList.innerHTML = '';
  q.opts.forEach((opt, j) => {
    const btn = document.createElement('button');
    btn.className = 'w-full text-left px-4 py-2.5 rounded-xl border-2 border-gray-100 hover:border-rose-300 text-sm transition-colors bg-white';
    btn.textContent = String.fromCharCode(65+j) + '. ' + opt;
    btn.addEventListener('click', () => {
      if (qAnswered) return;
      qAnswered = true;
      optList.querySelectorAll('button').forEach(b => b.disabled = true);
      const correct = j === q.ans;
      if (correct) {
        btn.className = 'w-full text-left px-4 py-2.5 rounded-xl border-2 border-green-400 bg-green-50 text-sm text-green-800';
        qScore++;
      } else {
        btn.className = 'w-full text-left px-4 py-2.5 rounded-xl border-2 border-red-400 bg-red-50 text-sm text-red-800';
        optList.querySelectorAll('button')[q.ans].className =
          'w-full text-left px-4 py-2.5 rounded-xl border-2 border-green-400 bg-green-50 text-sm text-green-800';
      }
      const fb = document.getElementById('quiz-feedback-box');
      fb.classList.remove('hidden');
      fb.className = 'mt-4 p-3 rounded-xl text-sm leading-relaxed ' +
        (correct ? 'bg-green-50 text-green-800 border border-green-200' : 'bg-red-50 text-red-800 border border-red-200');
      fb.innerHTML = (correct ? '<strong>✓ 正確！Chính xác!</strong><br>' : '<strong>✗ 再試一次。</strong><br>') + q.exp;
      document.getElementById('quiz-next-btn').classList.remove('hidden');
      updateScoreBar();
    });
    optList.appendChild(btn);
  });
  updateScoreBar();
}

document.getElementById('quiz-next-btn').addEventListener('click', () => {
  qIndex++;
  if (qIndex >= quizData.length) {
    document.getElementById('quiz-options-list').innerHTML = '';
    document.getElementById('quiz-num').textContent = '';
    document.getElementById('quiz-question-text').textContent = '';
    document.getElementById('quiz-audio-prompt').classList.add('hidden');
    document.getElementById('quiz-image-prompt').classList.add('hidden');
    document.getElementById('quiz-feedback-box').classList.add('hidden');
    document.getElementById('quiz-next-btn').classList.add('hidden');
    document.getElementById('quiz-progress-bar').style.width = '100%';
    document.getElementById('quiz-final-score').textContent = qScore;
    document.getElementById('quiz-done').classList.remove('hidden');
  } else {
    loadQuestion(qIndex);
  }
});

document.getElementById('quiz-restart').addEventListener('click', () => {
  qIndex = 0; qScore = 0;
  loadQuestion(0);
});

loadQuestion(0);

</script>

</Layout>
