[
  { idx:0, x: 5, y: 9 },
  { idx:1, x:37, y: 9 },
  { idx:2, x:73, y: 9 },
  { idx:3, x:26, y:55 },
  { idx:4, x:51, y:55 },
  { idx:5, x:93, y:55 },
].forEach(({ idx, x, y }) => {
  const h = document.createElement('button');
  h.title = ext1[idx]?.zh || '';
