/* ── TABS ── */
function switchTab(id) {
  document.querySelectorAll('.tab-section').forEach(s => s.classList.add('hidden'));
  document.getElementById('sec-' + id).classList.remove('hidden');
  document.querySelectorAll('.tab-btn').forEach(b => {
    const on = b.dataset.tab === id;
    b.classList.toggle('opacity-100', on);
    b.classList.toggle('border-white', on);
    b.classList.toggle('opacity-60', !on);
    b.classList.toggle('border-transparent', !on);
  });
}
document.querySelectorAll('.tab-btn').forEach(b => b.addEventListener('click', () => switchTab(b.dataset.tab)));
switchTab('vocab');

/* ── TAB SCROLL ── */
const tabScroll = document.getElementById('tab-scroll');
const tabPrev = document.getElementById('tab-prev');
const tabNext = document.getElementById('tab-next');
const TAB_STEP = 120;
function updateTabNav() {
  const atStart = tabScroll.scrollLeft <= 4;
  const atEnd = tabScroll.scrollLeft + tabScroll.clientWidth >= tabScroll.scrollWidth - 4;
  tabPrev.classList.toggle('hidden', atStart);
  tabNext.classList.toggle('hidden', atEnd);
}
tabPrev.addEventListener('click', () => { tabScroll.scrollBy({ left: -TAB_STEP, behavior: 'smooth' }); });
tabNext.addEventListener('click', () => { tabScroll.scrollBy({ left: TAB_STEP, behavior: 'smooth' }); });
tabScroll.addEventListener('scroll', updateTabNav, { passive: true });
updateTabNav();

/* ── FLIP CARD ── */
function makeFlipCard(zh, py, vi, wav, color) {
  const colors = {
    rose:   ['bg-rose-500',   'bg-rose-600',   'text-rose-100'],
    orange: ['bg-orange-500', 'bg-orange-600', 'text-orange-100'],
    yellow: ['bg-yellow-500', 'bg-yellow-600', 'text-yellow-100'],
  };
  const [bg, bgD, viC] = colors[color] || colors.rose;
  const div = document.createElement('div');
  div.className = 'flip-card h-28 cursor-pointer';
  div.innerHTML = `
    <div class="flip-card-inner">
      <div class="flip-card-front ${bg} text-white px-4 py-3 flex items-center justify-between rounded-2xl shadow-sm">
        <div class="flex-1 min-w-0">
          <div class="text-xl font-bold leading-tight">${zh}</div>
          <div class="text-xs opacity-80 font-mono mt-0.5">${py}</div>
        </div>
        <button class="ml-3 bg-white/20 hover:bg-white/30 rounded-full w-10 h-10 flex items-center justify-center flex-shrink-0 transition-colors"
          onclick="event.stopPropagation(); window.playAudio('${wav}')">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="white"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        </button>
      </div>
      <div class="flip-card-back ${bgD} text-white px-4 py-3 flex items-center rounded-2xl shadow-sm">
        <div class="flex-1 min-w-0">
          <div class="${viC} text-xs font-medium mb-1">Tiếng Việt</div>
          <div class="text-base font-bold leading-snug">${vi}</div>
        </div>
      </div>
    </div>`;
  div.addEventListener('click', () => div.classList.toggle('flipped'));
  return div;
}

