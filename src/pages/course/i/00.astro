  { zh:'吃藥', pinyin:'chī yào',   vn:'uống thuốc',  audio:'L0_47.wav', img:'L0_47.png', x:78, y:53 },
  { zh:'水',   pinyin:'shuǐ',      vn:'nước',        audio:'L0_43.wav', img:'L0_43.png', x:95, y:68 },
];

const EXTENDED = [
  { zh:'等一下', pinyin:'děng yí xià', vn:'Đợi một chút',      audio:'L0_48.wav', img:'L0_48.png' },
  { zh:'沒問題', pinyin:'méi wèn tí',  vn:'Không vấn đề',      audio:'L0_49.wav', img:'L0_49.png' },
  { zh:'好的',   pinyin:'hǎo de',      vn:'Được rồi',          audio:'L0_50.wav', img:'L0_50.png' },
  { zh:'可以',   pinyin:'kě yǐ',       vn:'Có thể / được',     audio:'L0_51.wav', img:'L0_51.png' },
  { zh:'不可以', pinyin:'bù kě yǐ',    vn:'Không được',        audio:'L0_52.wav', img:'L0_52.png' },
  { zh:'加油',   pinyin:'jiā yóu',     vn:'Cố lên!',           audio:'L0_53.wav', img:'L0_53.png' },
];

// ════════════════════════════════════════
// TAB SWITCHING
// ════════════════════════════════════════

const TAB_IDS = ['tones','initfinal','practical','extended'];
let currentTab = 'tones';

window.switchTab = function(id) {
  currentTab = id;
  document.querySelectorAll('.tab-section').forEach(s => s.classList.add('hidden'));
  document.getElementById('sec-' + id).classList.remove('hidden');
  document.querySelectorAll('.tab-btn').forEach(b => {
    const active = b.dataset.tab === id;
    b.classList.toggle('opacity-100', active);
    b.classList.toggle('border-white', active);
    b.classList.toggle('opacity-60', !active);
    b.classList.toggle('border-transparent', !active);
  });
};

// ════════════════════════════════════════
// TAB 1: TONES
// ════════════════════════════════════════

let currentToneAudio = null;

function renderTones() {
  const list = document.getElementById('tone-list');
  const markColors = ['bg-emerald-50 text-emerald-800', 'bg-sky-50 text-sky-800', 'bg-amber-50 text-amber-800', 'bg-red-50 text-red-800', 'bg-gray-50 text-gray-600'];
  list.innerHTML = TONES.map((t, i) => `
    <button onclick="showTone(${i})" class="w-full flex items-center gap-4 bg-white rounded-2xl shadow-sm border border-gray-100 px-4 py-4 hover:border-emerald-200 transition-all text-left active:scale-[0.98]">
      <div class="w-14 h-14 rounded-2xl ${markColors[i]} flex items-center justify-center flex-shrink-0">
        <span class="text-2xl font-black">${t.mark}</span>
      </div>
      <div class="flex-1 min-w-0">
        <p class="font-bold text-gray-800">${t.name}</p>
        <p class="text-xs text-gray-400">${t.vn}</p>
      </div>
      <div class="text-right flex-shrink-0">
        <p class="text-2xl font-black text-gray-700">${t.char}</p>
      </div>
      <svg class="flex-shrink-0 text-gray-300" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
    </button>
  `).join('');
}

window.showTone = function(i) {
  const t = TONES[i];
  currentToneAudio = t.audio;
  document.getElementById('tone-empty').style.display = 'none';
  const d = document.getElementById('tone-detail');
  d.style.display = 'flex';
  document.getElementById('td-curve').src  = `${BASE}/images/${t.toneImg}`;
  document.getElementById('td-name').textContent  = `${t.name} · ${t.vn}`;
  document.getElementById('td-desc').textContent  = t.desc;
  document.getElementById('td-char').textContent  = t.char;
  document.getElementById('td-img').src    = `${BASE}/images/${t.exImg}`;
  document.getElementById('td-word').textContent  = t.word;
  document.getElementById('td-pinyin').textContent = t.pinyin;
  document.getElementById('td-trans').textContent  = t.trans;
  window.playAudio(t.audio);
};

window.playCurrentTone = function() {
  if (currentToneAudio) window.playAudio(currentToneAudio);
};

// ════════════════════════════════════════
// TAB 2: INITIALS & FINALS
// ════════════════════════════════════════

let currentIFAudio = null;
let currentIF = 'initial';

window.switchIF = function(mode) {
  currentIF = mode;
  const isInit = mode === 'initial';
  document.getElementById('btn-initial').className = `flex-1 py-2 rounded-xl text-sm font-bold transition-all ${isInit ? 'bg-sky-500 text-white' : 'bg-gray-100 text-gray-500'}`;
  document.getElementById('btn-final').className   = `flex-1 py-2 rounded-xl text-sm font-bold transition-all ${!isInit ? 'bg-indigo-500 text-white' : 'bg-gray-100 text-gray-500'}`;
  document.getElementById('if-empty').style.display = '';
  document.getElementById('if-detail').style.display = 'none';
  renderIFGrid(isInit ? INITIALS : FINALS, isInit ? 'sky' : 'indigo');
};

const IF_BTN_CLS = {
  sky:    'px-4 py-2 rounded-xl font-bold text-sky-700 bg-sky-50 border border-sky-200 hover:bg-sky-100 transition-colors text-sm',
  indigo: 'px-4 py-2 rounded-xl font-bold text-indigo-700 bg-indigo-50 border border-indigo-200 hover:bg-indigo-100 transition-colors text-sm',
};

function renderIFGrid(items, color) {
  const grid = document.getElementById('if-grid');
  const groups = [...new Set(items.map(it => it.group))];
  grid.innerHTML = groups.map(g => {
    const gItems = items.filter(it => it.group === g);
    return `
      <div class="mb-4">
        <p class="text-xs font-bold text-gray-400 mb-2 uppercase tracking-wider">${g}</p>
        <div class="flex flex-wrap gap-2">
          ${gItems.map(it => {
            const realIdx = items.indexOf(it);
            return `<button onclick="showIF(${realIdx})" class="${IF_BTN_CLS[color]}">${it.pinyin}</button>`;
          }).join('')}
        </div>
      </div>`;
  }).join('');
}

window.showIF = function(i) {
  const items = currentIF === 'initial' ? INITIALS : FINALS;
  const color  = currentIF === 'initial' ? 'sky' : 'indigo';
  const it = items[i];
  currentIFAudio = it.audio;
  document.getElementById('if-empty').style.display = 'none';
  const d = document.getElementById('if-detail');
  d.style.display = 'flex';
  const letterEl = document.getElementById('ifd-letter');
  letterEl.textContent = it.pinyin;
  letterEl.className = `text-4xl font-black ${color === 'sky' ? 'text-sky-600' : 'text-indigo-600'} leading-none`;
  document.getElementById('ifd-vn').textContent   = it.vn;
  document.getElementById('ifd-img').src          = `${BASE}/images/${it.img}`;
  document.getElementById('ifd-word').textContent = it.word;
  document.getElementById('ifd-pinyin').textContent = it.wp;
  document.getElementById('ifd-trans').textContent   = it.trans;
  const playBtn = document.querySelector('#if-detail button');
  if (playBtn) playBtn.className = `w-10 h-10 ${color === 'sky' ? 'bg-sky-500 hover:bg-sky-600' : 'bg-indigo-500 hover:bg-indigo-600'} rounded-full flex items-center justify-center flex-shrink-0 transition-colors shadow`;
  window.playAudio(it.audio);
};

window.playCurrentIF = function() {
  if (currentIFAudio) window.playAudio(currentIFAudio);
};

// ════════════════════════════════════════
// TAB 3: PRACTICAL PINYIN
// ════════════════════════════════════════

let currentPracAudio = null;

function renderPractical() {
  const container = document.getElementById('hotspot-container');
  container.innerHTML = PRACTICAL.map((p, i) => `
    <button class="hotspot-btn" style="left:${p.x}%;top:${p.y}%;" onclick="showPrac(${i})" id="hspot-${i}">
    </button>`).join('');
}

window.showPrac = function(i) {
  const p = PRACTICAL[i];
  currentPracAudio = p.audio;
  document.querySelectorAll('.hotspot-btn').forEach((b, bi) => b.classList.toggle('active', bi === i));
  document.getElementById('prac-empty').style.display = 'none';
  const w = document.getElementById('prac-word');
  w.style.display = 'flex';
  document.getElementById('prac-img').src        = `${BASE}/images/${p.img}`;
  document.getElementById('prac-zh').textContent     = p.zh;
  document.getElementById('prac-pinyin').textContent = p.pinyin;
  document.getElementById('prac-vn').textContent     = p.vn;
  window.playAudio(p.audio);
};

window.playCurrentPrac = function() {
  if (currentPracAudio) window.playAudio(currentPracAudio);
};

// ════════════════════════════════════════
// TAB 5: EXTENDED LEARNING (flip cards)
// ════════════════════════════════════════

function renderExtended() {
  const list = document.getElementById('extended-list');
  list.innerHTML = EXTENDED.map((it, i) => `
    <div class="flip-card h-32 rounded-2xl cursor-pointer" onclick="this.classList.toggle('flipped')" id="ext-${i}">
      <div class="flip-card-inner rounded-2xl shadow-sm">
        <div class="flip-card-front bg-teal-500 rounded-2xl flex items-center justify-between px-5">
          <div>
            <p class="text-white text-2xl font-black leading-tight">${it.zh}</p>
            <p class="text-teal-100 text-sm font-medium">${it.pinyin}</p>
          </div>
          <button onclick="event.stopPropagation(); window.playAudio('${it.audio}')"
            class="w-11 h-11 bg-white/20 hover:bg-white/30 rounded-full flex items-center justify-center flex-shrink-0 transition-colors">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="white"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          </button>
        </div>
        <div class="flip-card-back bg-teal-700 rounded-2xl flex items-center gap-4 px-5">
          <img src="${BASE}/images/${it.img}" alt="" class="w-20 h-20 object-contain rounded-xl bg-white/10 flex-shrink-0" />
          <div>
            <p class="text-teal-100 text-xs font-medium uppercase tracking-wider mb-1">Tiếng Việt</p>
            <p class="text-white text-xl font-bold leading-tight">${it.vn}</p>
          </div>
        </div>
      </div>
    </div>`).join('');
}

// ════════════════════════════════════════
// INIT
// ════════════════════════════════════════

renderTones();
switchIF('initial');
renderPractical();
renderExtended();
</script>
</Layout>
