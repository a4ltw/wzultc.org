      <button onclick="event.stopPropagation(); window.playAudio('${d.wav}')" class="text-teal-600 bg-teal-50 hover:bg-teal-100 rounded-full w-8 h-8 flex items-center justify-center transition-colors text-sm">🔊</button>
    </div>
    <div class="text-xl font-bold text-gray-800 tracking-wide mb-1">${d.zh}</div>
    <div class="text-base text-teal-700 font-medium mb-2" style="font-family:Arial,sans-serif">${d.py}</div>
    <div class="text-sm text-gray-500 border-t border-gray-100 pt-2 flex items-start gap-2">
      <span class="text-xs bg-gray-100 text-gray-400 px-1.5 py-0.5 rounded mt-0.5 flex-shrink-0">VN</span>
      <span>${d.vi}</span>
