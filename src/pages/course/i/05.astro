/* ── AUDIO ── */
const globalAudio = document.getElementById('global-audio');
window.playAudio = function(wav) {
  globalAudio.src = BASE + '/audio/' + wav;
  globalAudio.currentTime = 0;
  globalAudio.play().catch(() => {});
};

/* ── TABS ── */
function switchTab(id) {
  document.querySelectorAll('.tab-section').forEach(s => s.classList.add('hidden'));
  document.getElementById('sec-' + id).classList.remove('hidden');
  document.querySelectorAll('.tab-btn').forEach(b => {
    const on = b.dataset.tab === id;
    b.classList.toggle('opacity-100', on);
    b.classList.toggle('border-white', on);
    b.classList.toggle('opacity-60', !on);
    b.classList.toggle('border-transparent', !on);
  });
}
document.querySelectorAll('.tab-btn').forEach(b => b.addEventListener('click', () => switchTab(b.dataset.tab)));
switchTab('vocab');

/* ── FLIP CARD ── */
function makeFlipCard(zh, py, vi, wav, color='teal') {
  const colors = {
    teal:   ['bg-teal-500',   'bg-teal-600',   'text-teal-100'],
    orange: ['bg-orange-500', 'bg-orange-600', 'text-orange-100'],
    yellow: ['bg-yellow-500', 'bg-yellow-600', 'text-yellow-100'],
  };
  const [bg, bgD, viC] = colors[color] || colors.teal;
  const div = document.createElement('div');
  div.className = 'flip-card h-28 cursor-pointer';
  div.innerHTML = `
    <div class="flip-card-inner">
      <div class="flip-card-front ${bg} text-white p-3 flex flex-col justify-between rounded-2xl shadow-sm">
        <div class="text-lg font-bold leading-tight">${zh}</div>
        <div class="text-xs opacity-80 font-mono">${py}</div>
      </div>
      <div class="flip-card-back ${bgD} text-white p-3 flex flex-col justify-between rounded-2xl shadow-sm">
        <div class="${viC} text-sm font-medium leading-snug">${vi}</div>
        <button class="self-end bg-white/20 hover:bg-white/30 rounded-full w-8 h-8 flex items-center justify-center transition-colors"
          onclick="event.stopPropagation(); playAudio('${wav}')">🔊</button>
      </div>
    </div>`;
  div.addEventListener('click', () => div.classList.toggle('flipped'));
  return div;
}

/* ── SECTION 1: 生詞 ── */
const vocabButtonsEl = document.getElementById('vocab-buttons');
const vocabDetailEmpty = document.getElementById('vocab-detail-empty');
const vocabDetailContent = document.getElementById('vocab-detail-content');
const vocabDetailVi = document.getElementById('vocab-detail-vi');
const vocabDetailImg = document.getElementById('vocab-detail-img');
const allVocabBtns = [];

vocab.forEach(v => {
  const btn = document.createElement('button');
  const isLong = v.zh.length > 4;
  btn.className = 'w-full flex items-center justify-between py-4 px-5 rounded-2xl border-2 border-slate-200 bg-white shadow-sm transition-all duration-200 active:scale-[0.98]';
  btn.innerHTML = `
    <div class="text-left">
      <div class="vocab-zh ${isLong ? 'text-xl' : 'text-2xl'} font-bold text-gray-800 leading-tight">${v.zh}</div>
      <div class="vocab-py text-sm text-gray-400 mt-0.5" style="font-family:Arial,sans-serif">${v.py}</div>
    </div>
    <span class="text-xl text-gray-300 flex-shrink-0">🔊</span>`;
  btn.addEventListener('click', () => {
    allVocabBtns.forEach(b => {
      b.className = 'w-full flex items-center justify-between py-4 px-5 rounded-2xl border-2 border-slate-200 bg-white shadow-sm transition-all duration-200 active:scale-[0.98]';
      b.querySelector('.vocab-zh').style.color = '';
      b.querySelector('.vocab-py').style.color = '';
    });
    btn.className = 'w-full flex items-center justify-between py-4 px-5 rounded-2xl border-2 border-teal-500 bg-teal-500 shadow-lg ring-4 ring-teal-100 transition-all duration-200 active:scale-[0.98]';
    btn.querySelector('.vocab-zh').style.color = 'white';
    btn.querySelector('.vocab-py').style.color = 'rgb(153 246 228)';
    window.playAudio(v.wav);
    vocabDetailEmpty.style.display = 'none';
    vocabDetailContent.style.display = 'flex';
    vocabDetailVi.textContent = v.vi;
    vocabDetailImg.src = BASE + '/images/' + v.img;
    vocabDetailImg.alt = v.zh;
  });
  allVocabBtns.push(btn);
  vocabButtonsEl.appendChild(btn);
});

/* ── SECTION 2: 句型練習 ── */
const sentenceChat = document.getElementById('sentence-chat');
const sentenceBtns = document.getElementById('sentence-btns');
sentences.forEach(s => {
  const btn = document.createElement('button');
  btn.className = 'w-full bg-gray-50 hover:bg-blue-50 border border-gray-200 text-left px-4 py-3 rounded-xl transition-colors flex items-center justify-between active:scale-[0.98]';
  btn.innerHTML = `<span class="text-[#0068ff] font-medium text-base" style="font-family:Arial,sans-serif">${s.py}</span><span class="text-gray-300 text-sm flex-shrink-0">▶</span>`;
  btn.addEventListener('click', () => {
    window.playAudio(s.wav);
    const bubble = document.createElement('div');
    bubble.className = 'flex justify-end w-full';
    bubble.innerHTML = `
      <div class="bg-[#e5efff] rounded-2xl rounded-tr-none p-3 max-w-[85%] shadow-sm border border-blue-100">
        <div class="flex justify-between items-start gap-3 mb-1">
          <div class="text-lg font-bold text-gray-800 tracking-wide whitespace-pre-line">${s.zh}</div>
          <button onclick="window.playAudio('${s.wav}')" class="w-8 h-8 rounded-full bg-blue-100 hover:bg-[#0068ff] hover:text-white text-[#0068ff] flex items-center justify-center flex-shrink-0 transition-colors text-sm">🔊</button>
        </div>
