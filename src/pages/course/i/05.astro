---
import Layout from '../../../layouts/Layout.astro';

const BASE = '/assets/course/l5';
---

<Layout title="第五課：行動協助 - WZULTC 台越照護華語" description="台越照護華語第五課互動練習，包含生詞、句型、情境對話影片、延伸學習。">

<div class="bg-teal-50 min-h-screen pb-24">

  <!-- Header -->
  <header class="bg-teal-600 text-white shadow-lg sticky top-0 z-30">
    <div class="max-w-3xl mx-auto px-4 py-3 flex items-center gap-3">
      <a href="/course/05" class="p-1 hover:bg-white/20 rounded-lg transition-colors text-white">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </a>
      <div>
        <h1 class="text-base font-bold leading-tight">第五課：行動協助</h1>
        <p class="text-xs opacity-80">Bài 5: Hỗ trợ di chuyển</p>
      </div>
    </div>
    <div class="max-w-3xl mx-auto overflow-x-auto scrollbar-none">
      <div class="flex border-t border-white/20 min-w-max md:min-w-0 md:w-full">
        {[
          ['vocab',    '生詞'],
          ['sentence', '句型'],
          ['video',    '對話影片'],
          ['dialogue', '情境對話'],
          ['ext1',     '延伸1'],
          ['ext2',     '延伸2'],
        ].map(([id, label]) => (
          <button class="tab-btn px-4 py-2 text-xs font-medium opacity-60 border-b-2 border-transparent transition-all whitespace-nowrap" data-tab={id}>{label}</button>
        ))}
      </div>
    </div>
  </header>

  <main class="max-w-3xl mx-auto px-4 pt-4 space-y-0">

    <!-- ===== SECTION 1: 生詞 ===== -->
    <section id="sec-vocab" class="tab-section -mx-4 md:mx-0">
      <div class="md:flex md:gap-6 md:items-start">
      <div id="vocab-buttons" class="overflow-y-auto px-4 pt-4 pb-3 space-y-2 max-h-[54vh] md:max-h-none md:flex-1"></div>
      <div class="sticky bottom-0 md:bottom-auto md:top-24 bg-white rounded-t-3xl md:rounded-2xl shadow-[0_-4px_20px_rgba(0,0,0,0.08)] md:shadow-sm border-t md:border border-gray-100 px-5 py-5 z-20 md:z-10 md:w-72 md:flex-shrink-0 md:mt-4">
        <div id="vocab-detail-empty" class="flex flex-col items-center gap-2 py-3 text-gray-400">
          <p class="text-sm font-medium text-gray-500">請點選生詞</p>
          <p class="text-xs">Nhấn vào từ vựng</p>
        </div>
        <div id="vocab-detail-content" style="display:none;" class="flex flex-col items-center gap-3">
          <span class="text-xs font-semibold text-teal-600 bg-teal-50 px-3 py-1 rounded-full">Tiếng Việt (越南文)</span>
          <p id="vocab-detail-vi" class="text-2xl font-bold text-teal-800 text-center leading-tight"></p>
          <img id="vocab-detail-img" src="" alt="" class="w-36 h-36 object-contain rounded-2xl bg-gray-50 border border-gray-100" />
        </div>
      </div>
      </div>
    </section>

    <!-- ===== SECTION 2: 句型練習 ===== -->
    <section id="sec-sentence" class="tab-section hidden -mx-4 md:mx-0 md:rounded-2xl md:overflow-hidden">
      <div class="flex flex-col" style="height:calc(100dvh - 8rem);">
        <div id="sentence-chat" class="flex-1 overflow-y-auto px-4 py-4 space-y-4 bg-[#e2e6f2]">
          <div class="flex justify-center">
            <span class="bg-black/20 text-white text-xs px-3 py-1 rounded-full">點擊下方拼音，開始練習 / Nhấn pinyin để bắt đầu</span>
          </div>
        </div>
        <div class="bg-white border-t border-gray-200 px-4 pt-3 pb-4 shadow-[0_-3px_10px_rgba(0,0,0,0.05)] flex-shrink-0">
          <p class="text-xs text-gray-400 mb-2">👇 請點擊拼音來發送句子：</p>
          <div id="sentence-btns" class="space-y-2 overflow-y-auto" style="max-height:32vh;"></div>
        </div>
      </div>
    </section>

    <!-- ===== SECTION 3: 情境對話影片 ===== -->
    <section id="sec-video" class="tab-section hidden space-y-3">
      <div class="bg-white rounded-2xl p-4 shadow-sm border-l-4 border-purple-500">
        <h2 class="font-bold text-purple-800 mb-1">情境對話影片 <span class="font-normal text-sm text-gray-400">Video hội thoại</span></h2>
        <p class="text-xs text-gray-400">影片播放中會自動暫停，請回答問題後繼續</p>
      </div>
      <div class="relative bg-black rounded-2xl overflow-hidden shadow-lg">
        <video id="dialogue-video" class="w-full" preload="metadata" playsinline>
          <source src={`${BASE}/video/L5_dialogue.mp4`} type="video/mp4" />
        </video>
        <div class="absolute inset-0 flex items-center justify-center bg-black/30" id="video-play-overlay">
          <button id="video-play-btn" class="bg-white/90 rounded-full w-16 h-16 flex items-center justify-center shadow-xl hover:bg-white transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="#0d9488"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          </button>
        </div>
      </div>
      <div id="video-quiz-overlay" class="hidden bg-white rounded-2xl p-5 shadow-md border border-purple-100">
        <p class="text-xs font-bold text-purple-500 mb-2">⏸ 影片暫停 — 請回答問題</p>
        <p id="vq-question" class="font-medium text-gray-800 mb-4 text-sm leading-relaxed"></p>
        <div id="vq-options" class="space-y-2"></div>
        <div id="vq-feedback" class="hidden mt-3 p-3 rounded-xl text-center text-sm font-bold"></div>
        <button id="vq-continue" class="hidden mt-3 w-full bg-purple-500 text-white py-2.5 rounded-xl text-sm font-medium">▶ 繼續播放</button>
      </div>
    </section>

    <!-- ===== SECTION 4: 情境對話 ===== -->
    <section id="sec-dialogue" class="tab-section hidden -mx-4 md:mx-0">
      <div class="w-full h-52 md:h-72 relative bg-gray-200 flex-shrink-0">
        <img src={`${BASE}/images/L5_dialogue.png`} alt="情境對話插圖" class="w-full h-full object-cover" loading="lazy" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent flex items-end p-4">
          <div class="text-white">
            <span class="bg-emerald-600 text-xs font-bold px-2 py-1 rounded mb-2 inline-block">情境一</span>
            <h2 class="text-lg font-bold">行動協助</h2>
            <p class="text-xs text-gray-200">Hỗ trợ di chuyển</p>
          </div>
        </div>
      </div>
      <div id="dialogue-list" class="overflow-y-auto px-4 py-4 space-y-3 max-h-[55vh] md:max-h-none"></div>
    </section>

    <!-- ===== SECTION 5: 延伸學習1 ===== -->
    <section id="sec-ext1" class="tab-section hidden space-y-3">
      <div class="bg-white rounded-2xl p-4 shadow-sm border-l-4 border-orange-500">
        <h2 class="font-bold text-orange-800 mb-1">延伸學習 1 <span class="font-normal text-sm text-gray-400">Học thêm 1</span></h2>
        <p class="text-xs text-gray-400">輔具設備・點卡片翻面看越南文，點 🔊 聽發音</p>
      </div>
      <div class="bg-white rounded-2xl p-4 shadow-sm">
        <img src={`${BASE}/images/L5_ext1.png`} alt="延伸學習插圖" class="w-full rounded-xl mb-4 object-contain max-h-48" loading="lazy" />
      </div>
      <div id="ext1-grid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3"></div>
    </section>

    <!-- ===== SECTION 6: 延伸學習2 ===== -->
    <section id="sec-ext2" class="tab-section hidden space-y-3">
      <div class="bg-white rounded-2xl p-4 shadow-sm border-l-4 border-yellow-500">
        <h2 class="font-bold text-yellow-800 mb-1">延伸學習 2 <span class="font-normal text-sm text-gray-400">Học thêm 2</span></h2>
        <p class="text-xs text-gray-400">選擇類別，點卡片翻面，點 🔊 聽發音</p>
      </div>
      <div class="flex gap-2 overflow-x-auto pb-1 scrollbar-none">
        {[
          ['輔助用品','Dụng cụ hỗ trợ'],
          ['行動動作','Động tác di chuyển'],
          ['安全提醒','Nhắc nhở an toàn'],
          ['身體狀態','Tình trạng cơ thể'],
          ['照護常用說法','Câu nói thường dùng'],
        ].map(([zh, vi], i) => (
          <button class="cat-btn flex-shrink-0 px-3 py-1.5 text-xs font-medium rounded-full border border-yellow-300 bg-white text-gray-600 transition-colors whitespace-nowrap" data-cat={i}>{zh} <span class="opacity-60">{vi}</span></button>
        ))}
      </div>
      <div id="ext2-grid" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3"></div>
    </section>

  </main>
</div>

<audio id="global-audio"></audio>

<style>
  .scrollbar-none::-webkit-scrollbar { display: none; }
  .scrollbar-none { -ms-overflow-style: none; scrollbar-width: none; }
  :global(.flip-card) { perspective: 800px; }
  :global(.flip-card-inner) { position: relative; width: 100%; height: 100%; transition: transform 0.45s ease; transform-style: preserve-3d; }
  :global(.flip-card.flipped .flip-card-inner) { transform: rotateY(180deg); }
  :global(.flip-card-front), :global(.flip-card-back) { position: absolute; inset: 0; backface-visibility: hidden; -webkit-backface-visibility: hidden; }
  :global(.flip-card-back) { transform: rotateY(180deg); }
</style>

