/* ── SECTION 5: 延伸學習1 ── */
const ext1Grid = document.getElementById('ext1-grid');
ext1.forEach(v => ext1Grid.appendChild(makeFlipCard(v.zh, v.py, v.vi, v.wav, 'orange')));

/* ── SECTION 6: 延伸學習2 ── */
let activeCat = 0;
const ext2Grid = document.getElementById('ext2-grid');
function renderExt2(cat) {
  ext2Grid.innerHTML = '';
  ext2.filter(v => v.cat === cat).forEach(v => ext2Grid.appendChild(makeFlipCard(v.zh, v.py, v.vi, v.wav, 'yellow')));
}
document.querySelectorAll('.cat-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    activeCat = parseInt(btn.dataset.cat);
    document.querySelectorAll('.cat-btn').forEach(b => {
      b.classList.toggle('bg-yellow-400', b === btn);
      b.classList.toggle('text-white', b === btn);
      b.classList.toggle('border-yellow-400', b === btn);
      b.classList.toggle('bg-white', b !== btn);
      b.classList.toggle('text-gray-600', b !== btn);
    });
    renderExt2(activeCat);
  });
});
document.querySelectorAll('.cat-btn')[0].click();

</script>

