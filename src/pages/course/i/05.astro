/* ── SECTION 3: 影片互動 ── */
const video = document.getElementById('dialogue-video');
const playOverlay = document.getElementById('video-play-overlay');
const playBtn = document.getElementById('video-play-btn');
const quizOverlay = document.getElementById('video-quiz-overlay');
const vqQuestion = document.getElementById('vq-question');
const vqOptions = document.getElementById('vq-options');
const vqFeedback = document.getElementById('vq-feedback');
const vqContinue = document.getElementById('vq-continue');
let vqAnswered = new Set();
let currentVQ = null;

playBtn.addEventListener('click', () => { playOverlay.classList.add('hidden'); video.play(); });
video.addEventListener('play', () => playOverlay.classList.add('hidden'));
video.addEventListener('pause', () => { if (!currentVQ) playOverlay.classList.remove('hidden'); });
video.addEventListener('timeupdate', () => {
  const t = video.currentTime;
  for (const vq of videoQuizzes) {
    if (!vqAnswered.has(vq.time) && t >= vq.time && t < vq.time + 0.5) {
      video.pause(); showVideoQuiz(vq); break;
    }
  }
});

function showVideoQuiz(vq) {
  currentVQ = vq;
  quizOverlay.classList.remove('hidden');
  vqQuestion.textContent = vq.q;
  vqOptions.innerHTML = '';
  vqFeedback.classList.add('hidden');
  vqContinue.classList.add('hidden');
  vq.opts.forEach((opt, i) => {
    const btn = document.createElement('button');
    btn.className = 'w-full text-left px-4 py-2.5 rounded-xl border-2 border-gray-100 hover:border-purple-300 text-sm transition-colors bg-white';
    btn.textContent = String.fromCharCode(65+i) + '. ' + opt;
    btn.addEventListener('click', () => {
      vqOptions.querySelectorAll('button').forEach(b => b.disabled = true);
      if (i === vq.ans) {
        btn.className = 'w-full text-left px-4 py-2.5 rounded-xl border-2 border-green-400 bg-green-50 text-sm text-green-800';
        vqFeedback.textContent = '✓ 正確！Chính xác!';
        vqFeedback.className = 'mt-3 p-3 rounded-xl text-center text-sm font-bold bg-green-100 text-green-700';
      } else {
        btn.className = 'w-full text-left px-4 py-2.5 rounded-xl border-2 border-red-400 bg-red-50 text-sm text-red-800';
        vqOptions.querySelectorAll('button')[vq.ans].className = 'w-full text-left px-4 py-2.5 rounded-xl border-2 border-green-400 bg-green-50 text-sm text-green-800';
        vqFeedback.textContent = '✗ 再試一次。答案是 ' + String.fromCharCode(65+vq.ans) + '. ' + vq.opts[vq.ans];
        vqFeedback.className = 'mt-3 p-3 rounded-xl text-center text-sm font-bold bg-red-100 text-red-700';
      }
      vqFeedback.classList.remove('hidden');
      vqAnswered.add(vq.time);
      vqContinue.classList.remove('hidden');
    });
    vqOptions.appendChild(btn);
  });
}
vqContinue.addEventListener('click', () => { quizOverlay.classList.add('hidden'); currentVQ = null; video.play(); });

/* ── SECTION 4: 情境對話 ── */
const dialogueListEl = document.getElementById('dialogue-list');
dialogueLines.forEach(d => {
