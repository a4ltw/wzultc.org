  { zh:'國家',    py:'guójiā',              vi:'quốc gia',               img:'L1_07.png', wav:'L1_07.mp3' },
  { zh:'台灣',    py:'Táiwān',              vi:'Đài Loan',               img:'L1_08.png', wav:'L1_08.mp3' },
  { zh:'越南',    py:'Yuènán',              vi:'Việt Nam',               img:'L1_09.png', wav:'L1_09.mp3' },
  { zh:'照護員',  py:'zhàohùyuán',          vi:'nhân viên chăm sóc',     img:'L1_10.png', wav:'L1_10.mp3' },
  { zh:'很高興認識你', py:'hěn gāoxìng rènshì nǐ', vi:'rất vui được gặp bạn', img:'L1_11.png', wav:'L1_11.mp3' },
