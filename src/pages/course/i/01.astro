const sentences = [
  { zh:'我叫（名字）。',                   py:'Wǒ jiào (míngzi).',                                      vi:'Tôi tên là (tên).',                                wav:'L1_12.mp3' },
  { zh:'我是（國家）人。\n我是越南人。',   py:'Wǒ shì (guójiā) rén.\nWǒ shì Yuènán rén.',             vi:'Tôi là người (quốc gia).\nTôi là người Việt Nam.', wav:'L1_13.mp3' },
  { zh:'你是照護員嗎？',                   py:'Nǐ shì zhàohùyuán ma?',                                  vi:'Bạn là nhân viên chăm sóc à?',                     wav:'L1_14.mp3' },
  { zh:'很高興認識你！',                   py:'Hěn gāoxìng rènshì nǐ!',                                 vi:'Rất vui được gặp bạn!',                             wav:'L1_15.mp3' },
];

const dialogueLines = [
  { role:'美玲', side:'left',  zh:'你好！請問你叫什麼名字？',           py:'Nǐ hǎo! Qǐngwèn nǐ jiào shénme míngzi?', vi:'Xin chào! Xin hỏi, bạn tên là gì?',                wav:'L1_16.mp3' },
  { role:'蘭',   side:'right', zh:'我叫蘭。我是越南人。你呢？',         py:'Wǒ jiào Lán. Wǒ shì Yuènán rén. Nǐ ne?', vi:'Tôi tên là Lan. Tôi là người Việt Nam. Còn bạn?',  wav:'L1_17.mp3' },
  { role:'美玲', side:'left',  zh:'我叫美玲，我是照護員。',              py:'Wǒ jiào Měilíng, wǒ shì zhàohùyuán.',     vi:'Tôi tên là Mỹ Linh, tôi là nhân viên chăm sóc.',   wav:'L1_18.mp3' },
  { role:'蘭',   side:'right', zh:'很高興認識你！',                       py:'Hěn gāoxìng rènshì nǐ!',                  vi:'Rất vui được gặp bạn!',                             wav:'L1_19.mp3' },
];

const ext1 = [
  { zh:'阿公',   py:'ā gōng',      vi:'Ông / ông nội',          wav:'L1_20.mp3' },
  { zh:'阿嬤',   py:'ā mà',        vi:'Bà / bà nội',            wav:'L1_21.mp3' },
  { zh:'護理長', py:'hù lǐ zhǎng', vi:'Trưởng điều dưỡng',      wav:'L1_22.mp3' },
  { zh:'早安',   py:'zǎo ān',      vi:'Chào buổi sáng',         wav:'L1_23.mp3' },
  { zh:'謝謝',   py:'xièxie',      vi:'Cảm ơn',                 wav:'L1_24.mp3' },
  { zh:'不客氣', py:'bú kèqi',     vi:'Không có gì',            wav:'L1_25.mp3' },
  { zh:'請問',   py:'qǐngwèn',     vi:'Xin hỏi',                wav:'L1_26.mp3' },
];

const ext2 = [
  { cat:0, zh:'午安',    py:'wǔ ān',        vi:'Chào buổi trưa',         wav:'L1_27.mp3' },
  { cat:0, zh:'晚安',    py:'wǎn ān',       vi:'Chúc ngủ ngon',          wav:'L1_28.mp3' },
  { cat:0, zh:'再見',    py:'zàijiàn',      vi:'Tạm biệt',               wav:'L1_29.mp3' },
  { cat:0, zh:'明天見',  py:'míngtiān jiàn',vi:'Hẹn gặp lại ngày mai',   wav:'L1_30.mp3' },
  { cat:1, zh:'不好意思',py:'bù hǎoyìsi',   vi:'Xin lỗi / Ngại quá',     wav:'L1_31.mp3' },
  { cat:1, zh:'對不起',  py:'duìbuqǐ',      vi:'Xin lỗi',                wav:'L1_32.mp3' },
  { cat:1, zh:'沒關係',  py:'méi guānxi',   vi:'Không sao đâu',          wav:'L1_33.mp3' },
  { cat:2, zh:'先生',    py:'xiān shēng',   vi:'Ông / anh',              wav:'L1_34.mp3' },
  { cat:2, zh:'太太',    py:'tài tai',      vi:'Bà / cô',                wav:'L1_35.mp3' },
  { cat:2, zh:'小姐',    py:'xiǎo jiě',     vi:'Cô / chị',               wav:'L1_36.mp3' },
  { cat:3, zh:'組長',    py:'zǔ zhǎng',     vi:'Tổ trưởng',              wav:'L1_37.mp3' },
  { cat:3, zh:'護士',    py:'hù shì',       vi:'Y tá',                   wav:'L1_38.mp3' },
  { cat:3, zh:'同事',    py:'tóng shì',     vi:'Đồng nghiệp',            wav:'L1_39.mp3' },
  { cat:3, zh:'醫生',    py:'yī shēng',     vi:'Bác sĩ',                 wav:'L1_40.mp3' },
