/* ── SECTION 5: 延伸學習1 ─────────────────────────────────── */
const ext1Grid = document.getElementById('ext1-grid');
ext1.forEach(v => ext1Grid.appendChild(makeFlipCard(v.zh, v.py, v.vi, v.wav, 'orange')));

if (!document.getElementById('ext1-pulse-style')) {
  const ps = document.createElement('style');
  ps.id = 'ext1-pulse-style';
  ps.textContent = '@keyframes ext1-pulse{0%{box-shadow:0 0 0 0 rgba(239,68,68,0.5)}70%{box-shadow:0 0 0 8px rgba(239,68,68,0)}100%{box-shadow:0 0 0 0 rgba(239,68,68,0)}}';
  document.head.appendChild(ps);
}
const ext1Map = document.getElementById('ext1-map');
[
  { idx:0, x:23, y:63 },
  { idx:1, x:42, y:58 },
  { idx:2, x:75, y:48 },
  { idx:3, x:16, y:14 },
  { idx:4, x:42, y:20 },
  { idx:5, x:58, y:11 },
  { idx:6, x:90, y:10 },
].forEach(({ idx, x, y }) => {
  const h = document.createElement('button');
  h.title = ext1[idx]?.zh || '';
  h.style.cssText = `position:absolute;left:${x}%;top:${y}%;width:24px;height:24px;border-radius:50%;background:rgba(239,68,68,0.92);border:2px solid white;transform:translate(-50%,-50%);cursor:pointer;animation:ext1-pulse 2s infinite;box-shadow:0 0 0 0 rgba(239,68,68,0.5);`;
  h.addEventListener('click', () => {
    const card = ext1Grid.children[idx];
    if (!card) return;
    card.scrollIntoView({ behavior:'smooth', block:'nearest' });
    card.classList.toggle('flipped');
    if (card.classList.contains('flipped')) window.playAudio(ext1[idx].wav);
    card.style.outline = '3px solid #f97316';
    card.style.outlineOffset = '3px';
    setTimeout(() => { card.style.outline=''; card.style.outlineOffset=''; }, 1500);
  });
  ext1Map.appendChild(h);
});

/* ── 校正模式 (URL: ?calibrate=1) ──────────────────────── */
if (new URLSearchParams(location.search).has('calibrate')) {
  const wrap = document.getElementById('ext1-map');
  if (wrap) {
    const banner = document.createElement('div');
    banner.style.cssText = 'position:absolute;top:0;left:0;right:0;background:rgba(234,179,8,0.9);color:#000;font-size:12px;font-weight:bold;padding:4px 8px;z-index:100;';
    banner.textContent = '📍 校正模式：點擊圖片取得座標';
    wrap.appendChild(banner);
    const display = document.createElement('div');
    display.style.cssText = 'position:absolute;bottom:8px;left:8px;background:rgba(0,0,0,0.75);color:#4ade80;font-size:13px;font-family:monospace;padding:4px 8px;border-radius:6px;z-index:100;';
    display.textContent = 'x: -, y: -';
    wrap.appendChild(display);
    wrap.style.cursor = 'crosshair';
    wrap.addEventListener('click', e => {
      const r = wrap.getBoundingClientRect();
      const x = Math.round((e.clientX - r.left) / r.width * 100);
      const y = Math.round((e.clientY - r.top)  / r.height * 100);
      display.textContent = `x: ${x}, y: ${y}`;
      display.style.background = 'rgba(0,100,0,0.85)';
      setTimeout(() => { display.style.background = 'rgba(0,0,0,0.75)'; }, 800);
    });
  }
}

/* ── SECTION 6: 延伸學習2 ─────────────────────────────────── */
