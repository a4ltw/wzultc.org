---
import Layout from '../../layouts/Layout.astro';

const images = [
  { src: '/assets/events/20260305-2/281D9D09-D41C-4511-AB9C-B11275F64AC9.jpg', alt: '跨域合作交流現場' },
  { src: '/assets/events/20260305-2/4DA65E3C-6EE7-4B1A-8D8E-8303B0B64C8B.jpg', alt: '跨域合作交流現場' },
  { src: '/assets/events/20260305-2/6866B18B-16CA-4F54-A388-F982FF34BCEE.jpg', alt: '跨域合作交流現場' },
  { src: '/assets/events/20260305-2/6A6780CA-2502-454D-84A8-F00AA3598E74.jpg', alt: '跨域合作交流現場' },
  { src: '/assets/events/20260305-2/CD825C47-814F-438F-B0D6-DEAEE2ABAA78.jpg', alt: '跨域合作交流現場' },
];
---

<Layout title="2026/03/05 傳藝系 × 醫療無障礙跨域合作 - WZULTC" description="傳藝系與醫療無障礙計畫跨域交流討論紀錄">
  <section class="py-16 container mx-auto px-4">
    <div class="max-w-4xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-8">
        <p class="text-teal-600 font-medium mb-2">2026/03/05</p>
        <h1 class="text-3xl md:text-4xl font-bold text-gray-800 mb-4">
          傳藝系 × 醫療無障礙跨域合作
        </h1>
        <p class="text-xl text-gray-600">
          用影像的力量，跨越語言與文化的隔閡
        </p>
      </div>

      <!-- QR Code -->
      <div class="flex flex-col items-center mb-10">
        <div class="bg-white p-3 rounded-xl shadow-md">
          <img
            src="https://api.qrserver.com/v1/create-qr-code/?size=120x120&data=https://wzultc.org/r/20260305-2"
            alt="QR Code"
            width="120"
            height="120"
            class="block"
          />
        </div>
        <p class="text-sm text-gray-400 mt-2">掃描分享本頁</p>
      </div>

      <!-- Content -->
      <article class="bg-white rounded-xl shadow-lg p-6 md:p-8 mb-10">
        <div class="prose prose-lg max-w-none text-gray-700 leading-relaxed">
          <p>
            3 月 5 日中午，我們在溫暖而充滿創意的氣氛中，舉辦了一場別開生面的跨域交流討論。這次邀請到本校傳藝系的同學們與<strong>蔡一峰主任</strong>，一起腦力激盪，討論如何將傳藝系的專業影像創作力與本計畫的醫療知識結合，拍出更有溫度、也更能幫助移工朋友的增能影片。
          </p>

          <p>
            活動由 Melody 老師開場，從撰寫本計畫的初心動念到看見的願景，進而說明目前的執行進度及現有素材，讓大家更了解我們正在努力推動的「就醫無障礙」。隨後由蔡一峰主任接棒，帶領同學思考如何用影像語言傳達理解與關懷。
          </p>

          <p>
            我們相信，透過傳藝系同學們的創意與專業，加上本計畫的實際場域經驗，未來一定能共創出更多實務應用的影音作品——用影像的力量跨越語言與文化的隔閡，讓每一位來自不同國家的朋友都能安心就醫、獲得支持。
          </p>
        </div>

        <!-- Tags -->
        <div class="flex flex-wrap gap-2 mt-6 pt-6 border-t border-gray-200">
          <span class="px-3 py-1 bg-teal-100 text-teal-700 rounded-full text-sm">國科會計畫</span>
          <span class="px-3 py-1 bg-blue-100 text-blue-700 rounded-full text-sm">跨域合作</span>
          <span class="px-3 py-1 bg-purple-100 text-purple-700 rounded-full text-sm">醫療無障礙</span>
          <span class="px-3 py-1 bg-green-100 text-green-700 rounded-full text-sm">影像創作</span>
          <span class="px-3 py-1 bg-orange-100 text-orange-700 rounded-full text-sm">越南移工</span>
        </div>
      </article>

      <!-- Photo Gallery -->
      <div class="mb-10">
        <h2 class="text-2xl font-bold text-gray-800 mb-6 flex items-center gap-2">
          <svg class="w-6 h-6 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          活動剪影
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {images.map((img) => (
            <div class="rounded-xl overflow-hidden shadow-md hover:shadow-lg transition-shadow">
              <img
                src={img.src}
                alt={img.alt}
                class="w-full h-64 object-cover"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      </div>

      <!-- Partners -->
      <div class="bg-gradient-to-br from-blue-50 to-teal-50 rounded-xl p-6 mb-10">
        <h3 class="text-lg font-bold text-gray-800 mb-4">合作單位</h3>
        <div class="flex flex-wrap gap-3">
          <span class="px-4 py-2 bg-white rounded-lg shadow-sm text-gray-700">文藻外語大學</span>
          <span class="px-4 py-2 bg-white rounded-lg shadow-sm text-gray-700">傳播藝術系</span>
        </div>
      </div>

      <!-- Back -->
      <div class="text-center pt-6 border-t border-gray-200">
        <a href="/" class="text-gray-500 hover:text-teal-500 transition-colors">
          ← 返回首頁 | Quay lại trang chủ
        </a>
      </div>
    </div>
  </section>
</Layout>
