---
import Layout from '../layouts/Layout.astro';

const beginnerCourses = [
  { number: '零', vietnamese: 'Bài học 0', level: '入門級', gradient: 'from-sky-500 to-teal-500', href: '/course/00' },
  { number: '一', vietnamese: 'Bài học 1', level: '入門級', gradient: 'from-sky-500 to-teal-500', href: '/course/01' },
  { number: '二', vietnamese: 'Bài học 2', level: '入門級', gradient: 'from-sky-500 to-teal-500', href: '/course/02' },
  { number: '三', vietnamese: 'Bài học 3', level: '入門級', gradient: 'from-sky-500 to-teal-500', href: '/course/03' },
  { number: '四', vietnamese: 'Bài học 4', level: '入門級', gradient: 'from-sky-500 to-teal-500', href: '/course/04' },
  { number: '五', vietnamese: 'Bài học 5', level: '入門級', gradient: 'from-sky-500 to-teal-500', href: '/course/05' },
  { number: '六', vietnamese: 'Bài học 6', level: '入門級', gradient: 'from-sky-500 to-teal-500', href: '/course/06' },
];

const basicCourses = [
  { number: '七', vietnamese: 'Bài học 7', level: '基礎級', gradient: 'from-rose-400 to-red-600', href: '/course/07' },
  { number: '八', vietnamese: 'Bài học 8', level: '基礎級', gradient: 'from-rose-400 to-red-600', href: '/course/08' },
  { number: '九', vietnamese: 'Bài học 9', level: '基礎級', gradient: 'from-rose-400 to-red-600', href: '/course/09' },
  { number: '十', vietnamese: 'Bài học 10', level: '基礎級', gradient: 'from-rose-400 to-red-600', href: '/course/10' },
  { number: '十一', vietnamese: 'Bài học 11', level: '基礎級', gradient: 'from-rose-400 to-red-600', href: '/course/11' },
  { number: '十二', vietnamese: 'Bài học 12', level: '基礎級', gradient: 'from-rose-400 to-red-600', href: '/course/12' },
];
---

<Layout title="華語教材 - WZULTC" description="文藻跨語照護華語課程，專為越南移工設計的照護華語教材">
  <div class="container mx-auto px-4 py-12">
    <!-- Page Header -->
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-800 mb-4">
        照護華語課程
      </h1>
      <p class="text-xl md:text-2xl text-gray-600">
        Khóa học Hoa ngữ Chăm sóc
      </p>
    </div>

    <!-- 入門級 Course Grid -->
    <div class="max-w-6xl mx-auto mb-12">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-700 mb-6 border-l-4 border-cyan-500 pl-4">
        入門級 <span class="text-lg font-normal text-gray-500">Sơ cấp</span>
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {beginnerCourses.map((course) => (
          <a
            href={course.href}
            class={`group bg-gradient-to-br ${course.gradient} rounded-xl p-8 text-white shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2`}
          >
            <h3 class="text-3xl font-bold mb-2">第{course.number}課</h3>
            <p class="text-lg opacity-90 mb-2">{course.vietnamese}</p>
            <p class="text-sm opacity-80">{course.level}</p>
            <div class="mt-4 flex justify-end">
              <svg
                class="w-6 h-6 transform group-hover:translate-x-1 transition-transform"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- 基礎級 Course Grid -->
    <div class="max-w-6xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-700 mb-6 border-l-4 border-red-500 pl-4">
        基礎級 <span class="text-lg font-normal text-gray-500">Cơ bản</span>
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {basicCourses.map((course) => (
          <a
            href={course.href}
            class={`group bg-gradient-to-br ${course.gradient} rounded-xl p-8 text-white shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2`}
          >
            <h3 class="text-3xl font-bold mb-2">第{course.number}課</h3>
            <p class="text-lg opacity-90 mb-2">{course.vietnamese}</p>
            <p class="text-sm opacity-80">{course.level}</p>
            <div class="mt-4 flex justify-end">
              <svg
                class="w-6 h-6 transform group-hover:translate-x-1 transition-transform"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- Back Link -->
    <div class="text-center mt-12">
      <a
        href="/"
        class="inline-flex items-center text-teal-600 hover:text-teal-700 font-medium transition-colors"
      >
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        返回網站首頁
      </a>
    </div>
  </div>
</Layout>
