---
import Layout from '../layouts/Layout.astro';

const beginnerCourses = [
  { number: '零', vietnamese: 'Bài học 0', slidesHref: '/course/00', interactiveHref: '/course/i/00' },
  { number: '一', vietnamese: 'Bài học 1', slidesHref: '/course/01', interactiveHref: '/course/i/01' },
  { number: '二', vietnamese: 'Bài học 2', slidesHref: '/course/02', interactiveHref: '/course/i/02' },
  { number: '三', vietnamese: 'Bài học 3', slidesHref: '/course/03', interactiveHref: null },
  { number: '四', vietnamese: 'Bài học 4', slidesHref: '/course/04', interactiveHref: null },
  { number: '五', vietnamese: 'Bài học 5', slidesHref: '/course/05', interactiveHref: null },
  { number: '六', vietnamese: 'Bài học 6', slidesHref: '/course/06', interactiveHref: null },
];

const basicCourses = [
  { number: '七',  vietnamese: 'Bài học 7',  slidesHref: '/course/07', interactiveHref: null },
  { number: '八',  vietnamese: 'Bài học 8',  slidesHref: '/course/08', interactiveHref: null },
  { number: '九',  vietnamese: 'Bài học 9',  slidesHref: '/course/09', interactiveHref: null },
  { number: '十',  vietnamese: 'Bài học 10', slidesHref: '/course/10', interactiveHref: null },
  { number: '十一', vietnamese: 'Bài học 11', slidesHref: '/course/11', interactiveHref: null },
  { number: '十二', vietnamese: 'Bài học 12', slidesHref: '/course/12', interactiveHref: null },
];
---

<Layout title="華語教材 - WZULTC" description="文藻跨語照護華語課程，專為越南移工設計的照護華語教材">
  <div class="max-w-2xl mx-auto px-4 py-10">

    <!-- Page Header -->
    <div class="text-center mb-10">
      <h1 class="text-3xl font-bold text-gray-800 mb-2">照護華語課程</h1>
      <p class="text-gray-500">Khóa học Hoa ngữ Chăm sóc</p>
    </div>

    <!-- 入門級 -->
    <div class="mb-10">
      <h2 class="text-lg font-bold text-gray-700 mb-4 border-l-4 border-cyan-500 pl-3">
        入門級 <span class="font-normal text-sm text-gray-400">Sơ cấp</span>
      </h2>
      <div class="space-y-3">
        {beginnerCourses.map((course) => (
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 px-5 py-4">
            <div class="flex items-center gap-2 mb-3">
              <span class="w-7 h-7 bg-sky-500 text-white text-xs font-bold rounded-full flex items-center justify-center flex-shrink-0">
                {course.number[0]}
              </span>
              <div>
                <p class="font-bold text-gray-800 leading-tight">第{course.number}課</p>
                <p class="text-xs text-gray-400">{course.vietnamese}</p>
              </div>
            </div>
            <div class="flex gap-2">
              <a
                href={course.slidesHref}
                class="flex-1 flex items-center justify-center gap-1.5 bg-sky-50 hover:bg-sky-100 text-sky-700 text-sm font-medium py-2 rounded-xl transition-colors border border-sky-200"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
                課程簡報
              </a>
              {course.interactiveHref ? (
                <a
                  href={course.interactiveHref}
                  class="flex-1 flex items-center justify-center gap-1.5 bg-sky-500 hover:bg-sky-600 text-white text-sm font-medium py-2 rounded-xl transition-colors shadow-sm"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                  互動課程
                </a>
              ) : (
                <span class="flex-1 flex items-center justify-center gap-1.5 bg-gray-50 text-gray-300 text-sm font-medium py-2 rounded-xl border border-gray-100 cursor-not-allowed">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                  互動課程
                </span>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- 基礎級 -->
    <div class="mb-10">
      <h2 class="text-lg font-bold text-gray-700 mb-4 border-l-4 border-rose-500 pl-3">
        基礎級 <span class="font-normal text-sm text-gray-400">Cơ bản</span>
      </h2>
      <div class="space-y-3">
        {basicCourses.map((course) => (
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 px-5 py-4">
            <div class="flex items-center gap-2 mb-3">
              <span class="w-7 h-7 bg-rose-500 text-white text-xs font-bold rounded-full flex items-center justify-center flex-shrink-0">
                {course.number[0]}
              </span>
              <div>
                <p class="font-bold text-gray-800 leading-tight">第{course.number}課</p>
                <p class="text-xs text-gray-400">{course.vietnamese}</p>
              </div>
            </div>
            <div class="flex gap-2">
              <a
                href={course.slidesHref}
                class="flex-1 flex items-center justify-center gap-1.5 bg-rose-50 hover:bg-rose-100 text-rose-700 text-sm font-medium py-2 rounded-xl transition-colors border border-rose-200"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
                課程簡報
              </a>
              {course.interactiveHref ? (
                <a
                  href={course.interactiveHref}
                  class="flex-1 flex items-center justify-center gap-1.5 bg-rose-500 hover:bg-rose-600 text-white text-sm font-medium py-2 rounded-xl transition-colors shadow-sm"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                  互動課程
                </a>
              ) : (
                <span class="flex-1 flex items-center justify-center gap-1.5 bg-gray-50 text-gray-300 text-sm font-medium py-2 rounded-xl border border-gray-100 cursor-not-allowed">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                  互動課程
                </span>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Back Link -->
    <div class="text-center">
      <a href="/" class="inline-flex items-center text-teal-600 hover:text-teal-700 text-sm font-medium transition-colors">
        <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        返回網站首頁
      </a>
    </div>

  </div>
</Layout>
