---
import Layout from '../layouts/Layout.astro';
import videosData from '../data/videos.json';

type VideoInfo = {
  title: string;
  lang: string;
  langLabel: string;
  type: string;
  count: number;
};

// 課程顯示順序
const COURSE_ORDER = ['Y01','Y02','Y03','A01','A02','B01','B02','C01','C02','C03','C04','F01','F02','F03','D01','D02','D03','D04','D05','D06','D07','D08'];

const SERIES_LABEL: Record<string, string> = {
  Y: '居家護理（高榮衛教）',
  A: '防護操作',
  B: '醫療器材操作',
  C: '移動照護',
  F: '個人衛生照護',
  D: '失智症照護',
};

const TYPE_LABEL: Record<string, string> = {
  S: '簡報',
  P: '流程圖',
};

const LANG_COLOR: Record<string, string> = {
  ZH: 'bg-blue-100 text-blue-700',
  VI: 'bg-yellow-100 text-yellow-700',
  ID: 'bg-red-100 text-red-700',
};

// 按課程分組
const grouped: Record<string, { title: string; codes: [string, VideoInfo][] }> = {};
for (const [code, info] of Object.entries(videosData) as [string, VideoInfo][]) {
  const course = code.split('-')[0];
  if (!grouped[course]) grouped[course] = { title: info.title, codes: [] };
  grouped[course].codes.push([code, info]);
}

// 排序 codes: S 優先，然後按 lang ZH/VI/ID，再按 P 編號
function sortCodes(codes: [string, VideoInfo][]) {
  return codes.sort(([a], [b]) => {
    const aType = a.split('-')[2]?.[0] ?? '';
    const bType = b.split('-')[2]?.[0] ?? '';
    if (aType !== bType) return aType === 'S' ? -1 : 1;
    const langOrder = ['ZH', 'VI', 'ID'];
    const aLang = a.split('-')[1];
    const bLang = b.split('-')[1];
    const li = langOrder.indexOf(aLang) - langOrder.indexOf(bLang);
    if (li !== 0) return li;
    return a.localeCompare(b);
  });
}

// 按系列分組
const seriesGroups: Record<string, string[]> = {};
for (const course of COURSE_ORDER) {
  if (!grouped[course]) continue;
  const series = course[0];
  if (!seriesGroups[series]) seriesGroups[series] = [];
  seriesGroups[series].push(course);
}
---

<Layout title="專技教材 - WZULTC" description="長照專業技術教材，含簡報與流程圖，提供中文、越南語、印尼語版本">
  <div class="bg-gradient-to-r from-blue-600 to-cyan-500 text-white py-10 text-center px-4">
    <h1 class="text-3xl md:text-4xl font-bold mb-3">長照專技教材</h1>
    <p class="text-lg opacity-90">Tài liệu kỹ thuật chăm sóc dài hạn ／ Materi teknis perawatan jangka panjang</p>
    <div class="flex justify-center gap-4 mt-4 flex-wrap text-sm">
      <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-blue-300 inline-block"></span> 中文</span>
      <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-yellow-300 inline-block"></span> Tiếng Việt</span>
      <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-red-300 inline-block"></span> Bahasa Indonesia</span>
    </div>
  </div>

  <div class="container mx-auto px-4 py-10 max-w-5xl">
    {Object.entries(seriesGroups).map(([series, courses]) => (
      <section class="mb-12">
        <h2 class="text-xl font-bold text-gray-700 mb-4 border-l-4 border-blue-500 pl-3">
          {SERIES_LABEL[series] ?? series}
        </h2>
        <div class="space-y-4">
          {courses.map((course) => {
            const { title, codes } = grouped[course];
            const sorted = sortCodes([...codes]);
            return (
              <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="bg-gradient-to-r from-blue-50 to-cyan-50 px-5 py-3 border-b border-gray-100">
                  <span class="font-mono text-xs text-blue-500 font-bold mr-2">{course}</span>
                  <span class="font-semibold text-gray-800">{title}</span>
                </div>
                <div class="px-5 py-4 flex flex-wrap gap-2">
                  {sorted.map(([code, info]) => {
                    const typeStr = code.split('-')[2] ?? '';
                    const typeBase = typeStr[0];
                    return (
                      <a
                        href={`/videos/${code}`}
                        class={`inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg border text-sm font-medium transition-all hover:shadow-sm hover:-translate-y-0.5 ${LANG_COLOR[info.lang]} border-current/20`}
                      >
                        <span class="opacity-60 text-xs">{TYPE_LABEL[typeBase] ?? typeStr}</span>
                        <span>{info.langLabel}</span>
                        <span class="opacity-50 text-xs">{info.count}頁</span>
                      </a>
                    );
                  })}
                </div>
              </div>
            );
          })}
        </div>
      </section>
    ))}
  </div>
</Layout>
